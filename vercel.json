{
    "regions": [
        "bom1"
    ],
    "functions": {
        ".vercel/output/functions/_render.func/*": {
            "runtime": "@vercel/node@3.x"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/_render"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}