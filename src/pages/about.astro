---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
import { db, experiences, education, publications, skills, bioContent, siteSettings } from "../db";

const siteConfig = await getDynamicConfig();

async function safe<T>(q: Promise<T>, fallback: T): Promise<T> {
  try { return await q; } catch { return fallback; }
}

const [experiencesList, educationList, publicationsList, skillsList, bioData, settingsData] = await Promise.all([
  safe(db.select().from(experiences).orderBy(experiences.startDate), [] as any[]),
  safe(db.select().from(education).orderBy(education.order), [] as any[]),
  safe(db.select().from(publications).orderBy(publications.order), [] as any[]),
  safe(db.select().from(skills).orderBy(skills.order), [] as any[]),
  safe(db.select().from(bioContent), [] as any[]),
  safe(db.select().from(siteSettings), [] as any[]),
]);

const bio: Record<string, string> = {};
for (const b of bioData as any[]) bio[b.key] = b.value;
const settings: Record<string, string> = {};
for (const s of settingsData as any[]) settings[s.key] = s.value;

const author = settings.author || siteConfig.author;
const location = settings.location || siteConfig.location;
const bioLong = bio.long || siteConfig.bio?.long || "";

function formatDate(s?: string) {
  if (!s) return "Present";
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

function initials(name: string) {
  return name
    .replace(/[^a-zA-Z0-9+#.]/g, "")
    .slice(0, 3)
    .toUpperCase();
}

const aboutSkilliconsMap: Record<string, string> = {
  "python": "python", "rust": "rust", "go": "go",
  "typescript": "ts", "javascript": "js", "django": "django",
  "fastapi": "fastapi", "react": "react", "next.js": "nextjs",
  "nextjs": "nextjs", "docker": "docker", "kubernetes": "kubernetes",
  "postgresql": "postgresql", "postgres": "postgresql",
  "redis": "redis", "mongodb": "mongodb", "kafka": "kafka",
  "node.js": "nodejs", "nodejs": "nodejs", "express": "express",
  "aws": "aws", "gcp": "gcp", "linux": "linux", "git": "git",
  "github": "github", "vscode": "vscode", "astro": "astro",
  "tailwind": "tailwindcss", "tailwindcss": "tailwindcss",
  "html": "html", "css": "css", "bash": "bash",
  "nginx": "nginx", "firebase": "firebase", "vercel": "vercel",
  "sqlite": "sqlite", "mysql": "mysql", "prisma": "prisma",
  "drizzle": "drizzle", "vite": "vite", "jest": "jest",
  "supabase": "supabase", "apache airflow": "airflow",
  "airflow": "airflow", "apache spark": "spark", "spark": "spark",
  "dbt": "dbt", "mojo": "mojo",
};
---

<BaseLayout title="About" description={`About ${author}.`}>
  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <div class="reveal">
        <p class="text-eyebrow">About</p>
        <h1 class="text-display mt-3 text-3xl sm:text-4xl">
          <span class="text-gradient">{author.split(" ")[0]}</span>
        </h1>
        {bioLong && (
          <p class="prose-mono mt-6 max-w-prose">{bioLong}</p>
        )}
        {bio.quote && (
          <blockquote class="mt-6 border-l-2 border-[var(--color-fg-subtle)] pl-4 text-base italic text-[var(--color-fg-muted)]">
            "{bio.quote}"
          </blockquote>
        )}
      </div>
    </div>
  </section>

  {experiencesList.length > 0 && (
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <h2 class="panel-title mb-6 reveal">
          Experience<span class="count-badge">{experiencesList.length}</span>
        </h2>
        <div class="panel">
          <div class="panel-top"></div>
          {([...experiencesList] as any[]).reverse().map((exp) => (
            <div class="row-card group">
              <div class="row-card-logo" aria-hidden="true">
                {exp.company.charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="row-card-title">
                  {exp.role}
                  <span class="text-[var(--color-fg-muted)]"> · {exp.company}</span>
                </h3>
                {exp.details && (
                  <p class="prose-mono mt-1 line-clamp-3">{exp.details}</p>
                )}
              </div>
              <div class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                {formatDate(exp.startDate)} — {formatDate(exp.endDate)}
              </div>
            </div>
          ))}
          <div class="panel-bottom"></div>
        </div>
      </div>
    </section>
  )}

  {educationList.length > 0 && (
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <h2 class="panel-title mb-6 reveal">
          Education<span class="count-badge">{educationList.length}</span>
        </h2>
        <div class="panel">
          <div class="panel-top"></div>
          {(educationList as any[]).map((edu) => (
            <div class="row-card group">
              <div class="row-card-logo" aria-hidden="true">
                {edu.institution.charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="row-card-title">{edu.institution}</h3>
                {edu.degree && <p class="row-card-meta">{edu.degree}</p>}
                {edu.details && (
                  <p class="prose-mono mt-1 line-clamp-2">{edu.details}</p>
                )}
              </div>
              <div class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                {formatDate(edu.startDate)} — {formatDate(edu.endDate)}
              </div>
            </div>
          ))}
          <div class="panel-bottom"></div>
        </div>
      </div>
    </section>
  )}

  {publicationsList.length > 0 && (
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <h2 class="panel-title mb-6 reveal">
          Publications<span class="count-badge">{publicationsList.length}</span>
        </h2>
        <div class="panel">
          <div class="panel-top"></div>
          {(publicationsList as any[]).map((pub) => (
            <a
              href={pub.url || "#"}
              target={pub.url ? "_blank" : undefined}
              rel={pub.url ? "noopener noreferrer" : undefined}
              class="row-card group"
            >
              <div class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] w-14 flex-shrink-0 pt-1">
                {formatDate(pub.date)}
              </div>
              <div class="min-w-0 flex-1 row-card-divider">
                <h3 class="row-card-title">{pub.title}</h3>
                {pub.venue && <p class="row-card-meta">{pub.venue}</p>}
                {pub.description && (
                  <p class="prose-mono mt-1 line-clamp-2">{pub.description}</p>
                )}
              </div>
              <div class="row-card-actions">
                {pub.url && (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                )}
              </div>
            </a>
          ))}
          <div class="panel-bottom"></div>
        </div>
      </div>
    </section>
  )}

  {skillsList.length > 0 && (
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <h2 class="panel-title mb-6 reveal">
          Stack<span class="count-badge">{skillsList.length}</span>
        </h2>
        <div class="flex flex-wrap gap-2 reveal">
          {(skillsList as any[]).map((s) => {
            const key = s.name.toLowerCase();
            const iconKey = aboutSkilliconsMap[key];
            return iconKey ? (
              <span class="icon-chip" title={s.name}>
                <img src={`https://skillicons.dev/icons?i=${iconKey}&theme=dark`} alt={s.name} class="icon-chip-img" />
              </span>
            ) : (
              <span class="icon-chip" title={s.name}>{initials(s.name)}</span>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 reveal">
        <div>
          <p class="text-eyebrow">Based in</p>
          <p class="mt-1.5 text-sm text-[var(--color-fg)]">{location || "—"}</p>
        </div>
        <div>
          <p class="text-eyebrow">Email</p>
          <p class="mt-1.5">
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-[var(--color-accent)] hover:underline">
              {siteConfig.email || "—"}
            </a>
          </p>
        </div>
        <div>
          <p class="text-eyebrow">Timezone</p>
          <p class="mt-1.5 text-sm text-[var(--color-fg)]">{siteConfig.timezone || "—"}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
