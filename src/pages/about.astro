---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
const siteConfig = await getDynamicConfig();
import {
  db,
  experiences,
  education,
  publications,
  interests,
  skills,
  bioContent,
  siteSettings,
} from "../db";

async function safeQuery(query: Promise<any[]>): Promise<any[]> {
  try {
    return await query;
  } catch (e) {
    console.warn('[about] DB query failed:', e);
    return [];
  }
}

const [
  experiencesList,
  educationList,
  publicationsList,
  interestsList,
  skillsList,
  bioData,
  settingsData,
] = await Promise.all([
  safeQuery(db.select().from(experiences).orderBy(experiences.order)),
  safeQuery(db.select().from(education).orderBy(education.order)),
  safeQuery(db.select().from(publications).orderBy(publications.order)),
  safeQuery(db.select().from(interests).orderBy(interests.order)),
  safeQuery(db.select().from(skills).orderBy(skills.order)),
  safeQuery(db.select().from(bioContent)),
  safeQuery(db.select().from(siteSettings)),
]);

const bio: Record<string, string> = {};
bioData.forEach((b) => (bio[b.key] = b.value));

const settings: Record<string, string> = {};
settingsData.forEach((s) => (settings[s.key] = s.value));

const author = settings.author || siteConfig.author;
const location = settings.location || siteConfig.location;
const bioLong = bio.long || siteConfig.bio.long;
const bioQuote = bio.quote || siteConfig.bio.quote;
const bioIntro =
  bio.intro ||
  `I'm ${author} (স্বাধীন বিশ্বাস), which means "Freedom" in Bengali. I'm a Backend Engineer and AI Systems Architect based in ${location}.`;
const bioStory =
  bio.story ||
  "With a deep love for problem-solving and building systems that scale, I've dedicated my career to creating backend infrastructure and AI solutions that help people express and share their ideas more effectively. I believe every problem has a solution — you just need to find the right algorithm.";

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<BaseLayout title="About">
  <div class="animate-fade-in max-w-6xl mx-auto">

    <!-- Page Header -->
    <div class="mb-16 pb-8 border-b border-glass-border">
      <p class="text-xs font-mono text-overlay0 mb-3">~/about</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-mono tracking-tight text-text mb-4">
        About <span class="text-accent">Me</span>
      </h1>
      <p class="text-lg font-serif text-subtext0 max-w-2xl leading-relaxed italic">
        {bioLong}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-16">

        <!-- 01. Who I Am -->
        <section class="animate-slide-up">
          <h2 class="text-lg font-mono text-text mb-6 flex items-center gap-3 pb-3 border-b border-glass-border">
            <span class="section-number">01.</span>
            Who I Am
          </h2>
          <div class="font-serif text-subtext0 leading-relaxed space-y-4 text-base sm:text-lg">
            <p>{bioIntro}</p>
            <p>{bioStory}</p>
            {bioQuote && (
              <blockquote class="pl-4 border-l-2 border-accent/40 italic text-subtext1 text-base">
                "{bioQuote}"
              </blockquote>
            )}
          </div>
        </section>

        <!-- 02. Experience -->
        {experiencesList.length > 0 && (
          <section class="animate-slide-up">
            <h2 class="text-lg font-mono text-text mb-6 flex items-center gap-3 pb-3 border-b border-glass-border">
              <span class="section-number">02.</span>
              Experience
            </h2>
            <div class="space-y-6 relative before:absolute before:left-0 before:top-2 before:bottom-2 before:w-px before:bg-surface1">
              {experiencesList.map((exp) => (
                <a
                  href={exp.url || '#'}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block relative pl-8"
                >
                  <div class="absolute left-0 top-2 w-2 h-2 rounded-full bg-accent/60 group-hover:bg-accent transition-colors"></div>
                  <div class="academic-card">
                    <div class="flex items-start gap-4">
                      <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-surface0/50 overflow-hidden flex items-center justify-center border border-surface0/50">
                        {exp.logoUrl ? (
                          <img src={exp.logoUrl} alt={exp.company} class="w-full h-full object-cover" />
                        ) : (
                          <span class="text-lg font-bold text-accent">{exp.company.charAt(0)}</span>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                          <h3 class="text-base font-semibold text-text group-hover:text-accent transition-colors">{exp.role}</h3>
                          <span class="text-xs font-mono text-overlay0 whitespace-nowrap">
                            {formatDate(exp.startDate)} — {exp.endDate ? formatDate(exp.endDate) : "Present"}
                          </span>
                        </div>
                        <p class="text-sm text-accent/80 font-mono">{exp.company}</p>
                        {exp.companyDescription && (
                          <p class="text-xs text-mauve/70 mt-1 italic">{exp.companyDescription}</p>
                        )}
                        {exp.details && (
                          <p class="text-sm text-subtext1 mt-2 leading-relaxed">{exp.details}</p>
                        )}
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- 03. Education -->
        {educationList.length > 0 && (
          <section class="animate-slide-up">
            <h2 class="text-lg font-mono text-text mb-6 flex items-center gap-3 pb-3 border-b border-glass-border">
              <span class="section-number">03.</span>
              Education
            </h2>
            <div class="space-y-6 relative before:absolute before:left-0 before:top-2 before:bottom-2 before:w-px before:bg-surface1">
              {educationList.map((edu) => (
                <div class="relative pl-8">
                  <div class="absolute left-0 top-2 w-2 h-2 rounded-full bg-blue/60"></div>
                  <div class="academic-card">
                    <div class="flex items-start gap-4">
                      <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-surface0/30 flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                        </svg>
                      </div>
                      <div class="flex-1">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                          <h3 class="text-base font-semibold text-text">{edu.institution}</h3>
                          <span class="text-xs font-mono text-overlay0 whitespace-nowrap">
                            {formatDate(edu.startDate)} — {edu.endDate ? formatDate(edu.endDate) : "Present"}
                          </span>
                        </div>
                        <p class="text-sm text-blue/80 font-mono">{edu.degree}</p>
                        {edu.details && (
                          <p class="text-sm text-subtext1 mt-2 whitespace-pre-line leading-relaxed">{edu.details}</p>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- 04. Publications -->
        {publicationsList.length > 0 && (
          <section class="animate-slide-up">
            <h2 class="text-lg font-mono text-text mb-6 flex items-center gap-3 pb-3 border-b border-glass-border">
              <span class="section-number">04.</span>
              Publications
            </h2>
            <div class="space-y-4">
              {publicationsList.map((pub, idx) => (
                <div class="academic-card">
                  <div class="flex flex-col gap-2">
                    <div class="flex justify-between items-start gap-4">
                      <h3 class="paper-title">
                        {pub.url ? (
                          <a href={pub.url} target="_blank" class="hover:text-accent transition-colors">
                            {pub.title}
                          </a>
                        ) : pub.title}
                      </h3>
                      <span class="text-xs font-mono text-overlay0 whitespace-nowrap flex-shrink-0">
                        {formatDate(pub.date)}
                      </span>
                    </div>
                    {pub.venue && (
                      <p class="text-xs font-mono text-accent/70">{pub.venue}</p>
                    )}
                    {pub.description && (
                      <p class="text-sm text-subtext1 leading-relaxed">{pub.description}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-8">

        <!-- Skills -->
        <div class="academic-card">
          <h3 class="text-sm font-mono text-text mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-mauve" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            Skills & Technologies
          </h3>
          <div class="flex flex-wrap gap-2">
            {skillsList.map((skill) => (
              <span class="text-xs px-2.5 py-1 bg-surface0/50 text-subtext0 rounded-lg border border-surface0 hover:text-accent hover:border-accent/30 transition-colors">
                {skill.name}
              </span>
            ))}
          </div>
        </div>

        <!-- Interests -->
        {interestsList.length > 0 && (
          <div class="academic-card">
            <h3 class="text-sm font-mono text-text mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
              Interests
            </h3>
            <div class="space-y-3">
              {interestsList.map((interest) => (
                <div class="flex items-start gap-3 p-2 rounded-lg hover:bg-surface0/20 transition-colors">
                  <div class="mt-0.5 text-lg">{interest.icon || '◆'}</div>
                  <div>
                    <div class="text-sm font-medium text-text">{interest.name}</div>
                    {interest.description && (
                      <div class="text-xs text-subtext0 mt-0.5 leading-relaxed">{interest.description}</div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Quick Info -->
        <div class="academic-card">
          <h3 class="text-sm font-mono text-text mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Quick Info
          </h3>
          <dl class="space-y-3 text-sm font-mono">
            <div class="flex items-start gap-2">
              <dt class="text-overlay0">Location:</dt>
              <dd class="text-text">{siteConfig.location}</dd>
            </div>
            <div class="flex items-start gap-2">
              <dt class="text-overlay0">Email:</dt>
              <dd><a href={`mailto:${siteConfig.email}`} class="text-accent hover:underline">{siteConfig.email}</a></dd>
            </div>
            <div class="flex items-start gap-2">
              <dt class="text-overlay0">Timezone:</dt>
              <dd class="text-text">{siteConfig.timezone}</dd>
            </div>
          </dl>
          <div class="mt-6 pt-4 border-t border-glass-border">
            <a
              href="https://cdn.swadhin.cv/swadhinbiswas.pdf"
              target="_blank"
              class="flex items-center justify-center gap-2 w-full bg-accent/10 border border-accent/30 hover:bg-accent/20 text-accent font-mono text-sm font-bold py-2.5 rounded-lg transition-all"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download CV
            </a>
          </div>
        </div>

        <!-- CTA -->
        <div class="bg-gradient-to-br from-accent/10 to-mauve/10 border border-accent/20 rounded-xl p-6">
          <h3 class="text-sm font-mono text-text mb-2">Let's work together</h3>
          <p class="text-xs text-subtext0 mb-4 leading-relaxed">
            I'm always open to discussing new projects, research collaborations, and opportunities.
          </p>
          <a
            href={`mailto:${siteConfig.email}`}
            class="inline-flex items-center gap-2 bg-accent text-gray-900 px-4 py-2 rounded-lg text-sm font-bold font-mono hover:bg-accent/90 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
