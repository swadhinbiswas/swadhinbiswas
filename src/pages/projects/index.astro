---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import { getDynamicConfig } from "../../lib/config";
import { db, projects } from "../../db";
import { desc, eq } from "drizzle-orm";

const siteConfig = await getDynamicConfig();

let dbProjects: any[] = [];
try {
  dbProjects = await db.select().from(projects).orderBy(desc(projects.order));
} catch {
  dbProjects = [];
}

const allProjects = dbProjects.map((p) => ({
  ...p,
  tags: (() => { try { return JSON.parse(p.tags || "[]"); } catch { return []; } })(),
}));

const featured = allProjects.filter((p) => p.featured);
const others = allProjects.filter((p) => !p.featured);

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: allProjects.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.name,
    description: p.description,
  })),
};
---

<BaseLayout title="Projects" description="Production platforms, open source tools, and research deployments.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl reveal">
        <p class="section-eyebrow">Projects</p>
        <h1 class="section-title mt-3">Selected work.</h1>
        <p class="section-description">
          Production platforms, open source tools, and research deployments. All projects are real and live in some form — full case studies are available on each project page.
        </p>
      </div>

      {allProjects.length === 0 ? (
        <div class="card p-16 text-center reveal">
          <p class="text-base font-medium text-white">No projects yet</p>
          <p class="mt-2 text-sm text-[var(--color-fg-muted)]">
            Add your projects from the admin panel — they'll appear here automatically.
          </p>
        </div>
      ) : (
        <div class="mt-12 space-y-16">
          {featured.length > 0 && (
            <div>
              <h2 class="text-eyebrow text-[var(--color-fg-subtle)] mb-6">Featured</h2>
              <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                {featured.map((p) => <ProjectCard project={p} />)}
              </div>
            </div>
          )}

          {others.length > 0 && (
            <div>
              {featured.length > 0 && (
                <h2 class="text-eyebrow text-[var(--color-fg-subtle)] mb-6">All projects</h2>
              )}
              <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                {others.map((p) => <ProjectCard project={p} />)}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
