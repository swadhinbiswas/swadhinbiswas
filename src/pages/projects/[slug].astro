---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, projects } from "../../db";
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkMath from "remark-math";
import remarkRehype from "remark-rehype";
import rehypeKatex from "rehype-katex";
import rehypeHighlight from "rehype-highlight";
import rehypeStringify from "rehype-stringify";
import "katex/dist/katex.min.css";
import "highlight.js/styles/github-dark.css";
import { getDynamicConfig } from "../../lib/config";

const { slug } = Astro.params;
let project: any = null;

try {
  const allProjects = await db.select().from(projects);
  project = allProjects.find((p) => {
    const pSlug = p.name
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, "")
      .replace(/[\s_-]+/g, "-")
      .replace(/^-+|-+$/g, "");
    return pSlug === slug;
  });
} catch (e) {
  console.warn("[projects/[slug]] DB query failed");
}

if (!project) {
  return Astro.redirect("/404");
}

const processor = unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkMath)
  .use(remarkRehype, { allowDangerousHtml: true })
  .use(rehypeKatex)
  .use(rehypeHighlight)
  .use(rehypeStringify, { allowDangerousHtml: true });

const rawContent = project.content || project.description || "";
const processedContent = await processor.process(rawContent);
const contentHtml = processedContent.toString();

const tags = (() => { try { return JSON.parse(project.tags || "[]"); } catch { return []; } })();
const projectDate = project.projectDate || project.createdAt || new Date().toISOString();

const siteConfig = await getDynamicConfig();
const siteUrl = (siteConfig.url || "https://swadhin.cv").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}/projects/${slug}/`;
const ogImage = project.image || `${siteUrl}/og-image.png`;
const publishedIso = new Date(projectDate).toISOString();
const tagKeywords = (Array.isArray(tags) ? tags : [])
  .map((t: unknown) => String(t).trim())
  .filter(Boolean)
  .slice(0, 10);

const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  headline: project.name,
  description: project.description,
  keywords: tagKeywords,
  image: [ogImage],
  datePublished: publishedIso,
  author: { "@type": "Person", name: siteConfig.author || "Swadhin Biswas" },
};
---

<BaseLayout
  title={project.name}
  description={project.description}
  image={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <meta property="article:published_time" content={publishedIso} />
  </Fragment>

  <article class="pb-24">
    <!-- Header -->
    <header class="border-b border-[var(--color-border)]">
      <div class="container-page py-16 sm:py-20">
        <a href="/projects" class="inline-flex items-center gap-2 text-sm text-[var(--color-fg-muted)] transition-colors hover:text-white">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          All projects
        </a>

        <div class="mt-8 max-w-3xl reveal">
          <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-fg-muted)]">
            {project.featured && (
              <span class="text-mono text-[10px] uppercase tracking-widest text-[var(--color-fg-subtle)]">
                Featured
              </span>
            )}
            <span class="text-mono text-sm">
              {new Date(projectDate).toLocaleDateString("en-US", { year: "numeric", month: "long" })}
            </span>
          </div>

          <h1 class="text-display mt-4 text-4xl text-white sm:text-5xl lg:text-6xl">
            {project.name}
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-[var(--color-fg-muted)] sm:text-xl">
            {project.description}
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            {project.url && (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                <span>Live demo</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
                </svg>
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                Source
              </a>
            )}
          </div>

          {tags.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-1.5">
              {tags.map((t: string) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- Featured image -->
    {project.image && (
      <div class="container-page mt-12">
        <div class="overflow-hidden rounded-xl border border-[var(--color-border)]">
          <img src={project.image} alt={project.name} class="w-full h-auto" loading="lazy" />
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="container-page mt-12 grid grid-cols-1 gap-12 lg:grid-cols-12">
      <div class="lg:col-span-8 lg:col-start-1">
        <div
          class="prose-content max-w-none"
          set:html={contentHtml}
        />
      </div>

      <aside class="lg:col-span-4">
        <div class="sticky top-28 space-y-6">
          <div class="card p-5">
            <p class="text-eyebrow">Project details</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="text-[var(--color-fg-subtle)]">Status</dt>
                <dd class="mt-0.5 text-white">{project.status || "Active"}</dd>
              </div>
              <div>
                <dt class="text-[var(--color-fg-subtle)]">Date</dt>
                <dd class="mt-0.5 text-white">
                  {new Date(projectDate).toLocaleDateString("en-US", { year: "numeric", month: "long" })}
                </dd>
              </div>
              {tags.length > 0 && (
                <div>
                  <dt class="text-[var(--color-fg-subtle)]">Stack</dt>
                  <dd class="mt-2 flex flex-wrap gap-1.5">
                    {tags.map((t: string) => (
                      <span class="tag">{t}</span>
                    ))}
                  </dd>
                </div>
              )}
            </dl>
          </div>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-content {
    color: var(--color-fg-muted);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .prose-content h1,
  .prose-content h2,
  .prose-content h3,
  .prose-content h4 {
    color: var(--color-fg);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.25;
  }
  .prose-content h1 { font-size: 2rem; }
  .prose-content h2 { font-size: 1.5rem; }
  .prose-content h3 { font-size: 1.25rem; }
  .prose-content p { margin: 1.25rem 0; }
  .prose-content a {
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s;
  }
  .prose-content a:hover {
    text-decoration-color: var(--color-accent);
  }
  .prose-content ul, .prose-content ol {
    padding-left: 1.5rem;
    margin: 1.25rem 0;
  }
  .prose-content li { margin: 0.5rem 0; }
  .prose-content code {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.35rem;
    border-radius: 0.3rem;
    font-size: 0.875em;
    color: var(--color-fg);
  }
  .prose-content pre {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content pre code {
    background: none;
    border: none;
    padding: 0;
  }
  .prose-content blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-fg);
    font-style: italic;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .prose-content th, .prose-content td {
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem;
    text-align: left;
  }
  .prose-content th { color: var(--color-fg); font-weight: 600; }
  .prose-content img { border-radius: 0.6rem; margin: 1.5rem 0; }
</style>
