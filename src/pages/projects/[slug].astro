---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, projects } from "../../db";
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkMath from "remark-math";
import remarkRehype from "remark-rehype";
import rehypeKatex from "rehype-katex";
import rehypeHighlight from "rehype-highlight";
import rehypeStringify from "rehype-stringify";
import "katex/dist/katex.min.css";
import "highlight.js/styles/github-dark.css";
import { getDynamicConfig } from "../../lib/config";

const { slug } = Astro.params;
let project: any = null;

try {
  const allProjects = await db.select().from(projects);
  project = allProjects.find((p) => {
    const pSlug = p.name
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, "")
      .replace(/[\s_-]+/g, "-")
      .replace(/^-+|-+$/g, "");
    return pSlug === slug;
  });
} catch (e) {
  console.warn("[projects/[slug]] DB query failed");
}

if (!project) {
  return Astro.redirect("/404");
}

const processor = unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkMath)
  .use(remarkRehype, { allowDangerousHtml: true })
  .use(rehypeKatex)
  .use(rehypeHighlight)
  .use(rehypeStringify, { allowDangerousHtml: true });

const rawContent = project.content || project.description || "";
const processedContent = await processor.process(rawContent);
const contentHtml = processedContent.toString();

const tags = (() => { try { return JSON.parse(project.tags || "[]"); } catch { return []; } })();
const projectDate = project.projectDate || project.createdAt || new Date().toISOString();

const siteConfig = await getDynamicConfig();
const siteUrl = (siteConfig.url || "https://swadhin.cv").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}/projects/${slug}/`;
const ogImage = project.image || `${siteUrl}/og-image.png`;
const publishedIso = new Date(projectDate).toISOString();
const tagKeywords = (Array.isArray(tags) ? tags : [])
  .map((t: unknown) => String(t).trim())
  .filter(Boolean)
  .slice(0, 10);

const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  headline: project.name,
  description: project.description,
  keywords: tagKeywords,
  image: [ogImage],
  datePublished: publishedIso,
  author: { "@type": "Person", name: siteConfig.author || "Swadhin Biswas" },
};
---

<BaseLayout
  title={project.name}
  description={project.description}
  image={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <meta property="article:published_time" content={publishedIso} />
  </Fragment>

  <article>
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <a href="/projects" class="text-mono inline-flex items-center gap-1.5 text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)] reveal">
          ← All projects
        </a>

        <div class="mt-8 reveal reveal-delay-1">
          <div class="flex flex-wrap items-center gap-3 text-mono text-xs text-[var(--color-fg-subtle)]">
            {project.featured && <span>★ Featured</span>}
            <span>{new Date(projectDate).toLocaleDateString("en-US", { year: "numeric", month: "short" })}</span>
            {project.status && <span>· {project.status}</span>}
          </div>

          <h1 class="text-display mt-3 text-3xl text-[var(--color-fg)] sm:text-4xl">
            <span class="text-gradient">{project.name}</span>
          </h1>

          <p class="prose-mono mt-4 max-w-prose">{project.description}</p>

          <div class="mt-6 flex flex-wrap items-center gap-2">
            {project.url && (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                Live demo →
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
                Source
              </a>
            )}
          </div>

          {tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-1.5">
              {tags.map((t: string) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    {project.image && (
      <section class="screen-line-after">
        <div class="container-narrow py-8 sm:py-12">
          <div class="overflow-hidden rounded-md border border-[var(--color-edge)]">
            <img src={project.image} alt={project.name} class="w-full h-auto" loading="lazy" />
          </div>
        </div>
      </section>
    )}

    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <div class="prose-content" set:html={contentHtml} />
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .prose-content {
    color: var(--color-fg-muted);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .prose-content h1,
  .prose-content h2,
  .prose-content h3,
  .prose-content h4 {
    color: var(--color-fg);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.25;
  }
  .prose-content h1 { font-size: 2rem; }
  .prose-content h2 { font-size: 1.5rem; }
  .prose-content h3 { font-size: 1.25rem; }
  .prose-content p { margin: 1.25rem 0; }
  .prose-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-style: wavy;
    text-decoration-color: var(--color-accent-2, var(--color-edge-strong));
    text-underline-offset: 4px;
    transition: all 0.2s ease;
  }
  .prose-content a:hover {
    color: var(--color-fg);
    text-decoration-color: var(--color-accent);
  }
  .prose-content ul, .prose-content ol {
    padding-left: 1.5rem;
    margin: 1.25rem 0;
  }
  .prose-content li { margin: 0.5rem 0; }
  .prose-content li::marker { color: var(--color-accent); }
  .prose-content code {
    background-color: rgba(199, 146, 234, 0.1);
    border: 1px solid var(--color-edge);
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
    font-size: 0.875em;
    color: var(--color-accent);
    font-family: var(--font-mono);
  }
  .prose-content pre {
    background-color: var(--color-card);
    border: 2px solid var(--color-edge);
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-fg-muted);
  }
  .prose-content blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-fg);
    font-style: italic;
    background: rgba(199, 146, 234, 0.04);
    border-radius: 0 8px 8px 0;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .prose-content th, .prose-content td {
    border-bottom: 1px solid var(--color-edge);
    padding: 0.75rem;
    text-align: left;
  }
  .prose-content th { color: var(--color-fg); font-weight: 700; }
  .prose-content img { border-radius: 12px; margin: 1.5rem 0; border: 2px solid var(--color-edge); }
</style>
