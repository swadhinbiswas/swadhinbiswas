---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
import { db, publications } from "../db";

const siteConfig = await getDynamicConfig();

async function safe<T>(q: Promise<T>, fallback: T): Promise<T> {
  try { return await q; } catch { return fallback; }
}

const publicationsList = await safe(
  db.select().from(publications).orderBy(publications.order),
  [] as any[]
);

function formatDate(s?: string) {
  if (!s) return "—";
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<BaseLayout title="Research" description={`Research and publications by ${siteConfig.author}.`}>
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl reveal">
        <p class="section-eyebrow">Research</p>
        <h1 class="section-title mt-3">Selected publications.</h1>
        <p class="section-description">
          Peer-reviewed and preprint work in AI systems, ML infrastructure, and applied research.
        </p>
      </div>

      <div class="mt-12">
        {publicationsList.length === 0 ? (
          <div class="card p-16 text-center reveal">
            <p class="text-base font-medium text-white">No publications yet</p>
            <p class="mt-2 text-sm text-[var(--color-fg-muted)]">
              Add research from the admin panel — it will appear here automatically.
            </p>
          </div>
        ) : (
          <div class="space-y-3">
            {(publicationsList as any[]).map((pub, i) => (
              <article
                class="card card-hover group p-6 sm:p-8 reveal halo"
                style={`transition-delay: ${i * 50}ms`}
              >
                <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
                  <div class="md:col-span-2">
                    <p class="text-mono text-sm text-[var(--color-fg-subtle)]">
                      {formatDate(pub.date)}
                    </p>
                  </div>

                  <div class="md:col-span-8">
                    <h3 class="text-lg font-semibold text-white transition-colors group-hover:text-[var(--color-accent)]">
                      {pub.url ? (
                        <a href={pub.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
                      ) : pub.title}
                    </h3>
                    {pub.venue && (
                      <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{pub.venue}</p>
                    )}
                    {pub.description && (
                      <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-[var(--color-fg-muted)]">
                        {pub.description}
                      </p>
                    )}
                  </div>

                  <div class="md:col-span-2 flex md:justify-end">
                    {pub.url && (
                      <a
                        href={pub.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-mono text-xs uppercase tracking-widest text-[var(--color-fg-muted)] transition-colors hover:text-white"
                      >
                        Read paper →
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {publicationsList.length > 0 && (
    <section class="section border-t border-[var(--color-border)]">
      <div class="container-page text-center reveal">
        <h2 class="text-2xl font-semibold tracking-tight text-white">Interested in collaboration?</h2>
        <p class="mx-auto mt-3 max-w-xl text-[var(--color-fg-muted)]">
          Always open to discussing research ideas, applied problems, and joint publications.
        </p>
        <a href="/contact" class="btn btn-primary mt-8 inline-flex">
          Get in touch
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  )}
</BaseLayout>
