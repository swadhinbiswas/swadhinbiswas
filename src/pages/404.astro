---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist." noindex>
  <section class="screen-line-after">
    <div class="container-narrow flex min-h-[70vh] flex-col items-start justify-center py-16">
      <div class="reveal">
        <p class="text-eyebrow">Error 404</p>
        <h1 class="text-display mt-3 text-4xl sm:text-5xl">
          <span class="text-gradient">Page not found</span>
        </h1>
        <p class="prose-mono mt-4 max-w-prose">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="/" class="btn btn-primary">Back to home →</a>
          <a href="/projects" class="btn btn-outline">View projects</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
