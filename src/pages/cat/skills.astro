---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, skills } from "../../db";
import { asc } from "drizzle-orm";

const skillRows = await db.select().from(skills).orderBy(asc(skills.order));
const grouped: Record<string, typeof skillRows> = {};
skillRows.forEach(s => {
  const cat = s.category || "general";
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(s);
});
---

<AdminLayout title="Skills">
  <h1 class="text-2xl font-bold mb-6">Skills ({skillRows.length})</h1>
  
  <div class="space-y-6 max-w-3xl">
    {Object.entries(grouped).map(([cat, skills]) => (
      <div>
        <h2 class="text-lg font-semibold text-cyan-400 mb-3 capitalize">{cat}</h2>
        <div class="flex flex-wrap gap-2">
          {skills.map((s) => (
            <div class:list={["px-3 py-1.5 rounded-lg text-sm border", s.tier === "core" ? "border-cyan-400/50 bg-cyan-400/10 text-cyan-300" : "border-white/10 bg-white/5 text-gray-300"]}>
              {s.name}
              {s.tier === "core" && <span class="ml-1 text-[10px] text-cyan-400">●</span>}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
  
  <p class="mt-6 text-sm text-gray-500">Edit skills via the API at <code class="text-cyan-400">/api/admin/skills</code></p>
</AdminLayout>
