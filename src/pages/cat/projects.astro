---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, projects } from "../../db";
import { asc } from "drizzle-orm";

const projRows = await db.select().from(projects).orderBy(asc(projects.order));
---

<AdminLayout title="Projects">
  <h1 class="text-2xl font-bold mb-6">Projects</h1>
  
  <div class="space-y-4 max-w-3xl">
    {projRows.map((proj) => (
      <div class="p-4 rounded-xl border border-white/10 bg-white/5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold">{proj.name}</h3>
            <p class="text-gray-300 text-sm mt-1">{proj.description}</p>
            {proj.github && (
              <a href={proj.github} target="_blank" rel="noopener noreferrer" class="text-cyan-400 text-xs mt-2 inline-block hover:underline">GitHub →</a>
            )}
          </div>
          <div class="text-right">
            {proj.stars ? <span class="text-yellow-400 text-sm">★ {proj.stars}</span> : null}
          </div>
        </div>
      </div>
    ))}
  </div>
  
  <p class="mt-6 text-sm text-gray-500">Edit projects via the API at <code class="text-cyan-400">/api/admin/projects</code></p>
</AdminLayout>
