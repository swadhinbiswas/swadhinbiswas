---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, experiences } from "../../db";
import { asc } from "drizzle-orm";

const expRows = await db.select().from(experiences).orderBy(asc(experiences.order));
---

<AdminLayout title="Experience">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Experience</h1>
    <button onclick="document.getElementById('add-form').classList.toggle('hidden')" class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-black font-semibold rounded-lg transition-colors text-sm">+ Add Experience</button>
  </div>

  <!-- Add Form -->
  <div id="add-form" class="hidden mb-6 p-4 rounded-xl border border-cyan-400/30 bg-cyan-400/5">
    <h2 class="text-lg font-semibold mb-4">New Experience</h2>
    <form id="create-form" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1">Company</label>
          <input type="text" name="company" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Role</label>
          <input type="text" name="role" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">URL</label>
          <input type="url" name="url" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Logo URL</label>
          <input type="url" name="logoUrl" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Start Date</label>
          <input type="date" name="startDate" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">End Date</label>
          <input type="date" name="endDate" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
        </div>
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Details</label>
        <textarea name="details" rows="3" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400"></textarea>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-black font-semibold rounded-lg transition-colors text-sm">Save</button>
        <button type="button" onclick="document.getElementById('add-form').classList.add('hidden')" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg transition-colors text-sm">Cancel</button>
      </div>
    </form>
  </div>

  <!-- List -->
  <div class="space-y-3 max-w-3xl">
    {expRows.map((exp) => (
      <div class="p-4 rounded-xl border border-white/10 bg-white/5 group">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="font-semibold">{exp.role}</h3>
            <p class="text-cyan-400 text-sm">{exp.company}</p>
            <p class="text-gray-500 text-xs mt-1">{exp.startDate} — {exp.endDate || "Present"}</p>
            {exp.details && <p class="text-gray-300 text-sm mt-2">{exp.details}</p>}
          </div>
          <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button onclick={`editExp(${JSON.stringify(exp).replace(/"/g, '&quot;')})`} class="px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded text-xs hover:bg-yellow-500/30">Edit</button>
            <button onclick={`deleteExp(${exp.id})`} class="px-3 py-1 bg-red-500/20 text-red-400 rounded text-xs hover:bg-red-500/30">Delete</button>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50 p-4">
    <div class="bg-[#111] border border-white/10 rounded-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <h2 class="text-lg font-semibold mb-4">Edit Experience</h2>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" name="id" />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Company</label>
            <input type="text" name="company" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Role</label>
            <input type="text" name="role" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">URL</label>
            <input type="url" name="url" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Logo URL</label>
            <input type="url" name="logoUrl" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Start Date</label>
            <input type="date" name="startDate" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">End Date</label>
            <input type="date" name="endDate" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400" />
          </div>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Details</label>
          <textarea name="details" rows="3" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-cyan-400"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="submit" class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-black font-semibold rounded-lg transition-colors text-sm">Update</button>
          <button type="button" onclick="document.getElementById('edit-modal').classList.add('hidden')" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg transition-colors text-sm">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  function toast(msg: string, ok = true) {
    const el = document.createElement("div");
    el.className = `fixed top-4 right-4 px-4 py-2 rounded-lg text-sm z-50 ${ok ? "bg-green-500/20 text-green-400 border border-green-500/30" : "bg-red-500/20 text-red-400 border border-red-500/30"}`;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 3000);
  }

  // Create
  document.getElementById("create-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form).entries());
    const res = await fetch("/api/admin/experiences", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    if (res.ok) { toast("Created!"); setTimeout(() => location.reload(), 500); }
    else { toast("Failed", false); }
  });

  // Edit
  (window as any).editExp = function(exp: any) {
    const form = document.getElementById("edit-form") as HTMLFormElement;
    form.id.value = exp.id;
    form.company.value = exp.company || "";
    form.role.value = exp.role || "";
    form.url.value = exp.url || "";
    form.logoUrl.value = exp.logoUrl || "";
    form.startDate.value = exp.startDate || "";
    form.endDate.value = exp.endDate || "";
    form.details.value = exp.details || "";
    document.getElementById("edit-modal")!.classList.remove("hidden");
  };

  document.getElementById("edit-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form).entries());
    data.id = Number(data.id);
    const res = await fetch("/api/admin/experiences", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    if (res.ok) { toast("Updated!"); setTimeout(() => location.reload(), 500); }
    else { toast("Failed", false); }
  });

  // Delete
  (window as any).deleteExp = async function(id: number) {
    if (!confirm("Delete this experience?")) return;
    const res = await fetch("/api/admin/experiences", {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id }),
    });
    if (res.ok) { toast("Deleted!"); setTimeout(() => location.reload(), 500); }
    else { toast("Failed", false); }
  };
</script>
