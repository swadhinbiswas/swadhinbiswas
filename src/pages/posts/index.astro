---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { db, posts as postsTable } from '../../db';
import { desc, eq } from 'drizzle-orm';

let posts: any[] = [];
try {
  const rows = await db
    .select()
    .from(postsTable)
    .where(eq(postsTable.draft, false))
    .orderBy(desc(postsTable.publishedAt));
  posts = rows.map((p) => ({
    slug: p.slug,
    title: p.title,
    description: p.description || "",
    publishedAt: p.publishedAt,
    tags: (() => { try { return JSON.parse(p.tags || "[]"); } catch { return []; } })(),
  }));
} catch {
  posts = [];
}

function formatDate(date: any) {
  const d = date instanceof Date ? date : new Date(date);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title="Blog" description="Essays on systems, ML infrastructure, and engineering practice.">
  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <div class="reveal">
        <p class="text-eyebrow">Blog</p>
        <h1 class="text-display mt-3 text-3xl sm:text-4xl text-gradient">Essays & notes</h1>
        <p class="prose-mono mt-4 max-w-prose">
          Thoughts on systems, ML infrastructure, and engineering practice.
        </p>
      </div>
    </div>
  </section>

  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      {posts.length === 0 ? (
        <p class="text-sm text-[var(--color-fg-muted)] reveal">No articles yet.</p>
      ) : (
        <div class="panel">
          <div class="panel-top"></div>
          {posts.map((post) => (
            <a href={`/posts/${post.slug}`} class="row-card group">
              <div class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] w-24 flex-shrink-0 pt-1">
                {formatDate(post.publishedAt)}
              </div>
              <div class="min-w-0 flex-1 row-card-divider">
                <h3 class="row-card-title">{post.title}</h3>
                {post.description && (
                  <p class="prose-mono mt-1 line-clamp-2">{post.description}</p>
                )}
                {post.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {post.tags.slice(0, 3).map((t: string) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="row-card-actions">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
          <div class="panel-bottom"></div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
