---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { db, posts as postsTable } from '../../db';
import { desc, eq } from 'drizzle-orm';

let posts: any[] = [];
try {
  const rows = await db
    .select()
    .from(postsTable)
    .where(eq(postsTable.draft, false))
    .orderBy(desc(postsTable.publishedAt));
  posts = rows.map((p) => ({
    slug: p.slug,
    title: p.title,
    description: p.description || "",
    publishedAt: p.publishedAt,
    tags: (() => { try { return JSON.parse(p.tags || "[]"); } catch { return []; } })(),
  }));
} catch {
  posts = [];
}

function formatDate(date: any) {
  const d = date instanceof Date ? date : new Date(date);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Writing" description="Essays on systems, ML infrastructure, and engineering practice.">
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl reveal">
        <p class="section-eyebrow">Writing</p>
        <h1 class="section-title mt-3">Essays & notes.</h1>
        <p class="section-description">
          Thoughts on systems, ML infrastructure, and engineering practice.
        </p>
      </div>

      <div class="mt-12">
        {posts.length === 0 ? (
          <div class="card p-16 text-center reveal">
            <p class="text-base font-medium text-white">No articles yet</p>
            <p class="mt-2 text-sm text-[var(--color-fg-muted)]">
              New writing will appear here once published from the admin panel.
            </p>
          </div>
        ) : (
          <div class="space-y-3">
            {posts.map((post, i) => (
              <a
                href={`/posts/${post.slug}`}
                class="card card-hover group p-6 sm:p-7 reveal"
                style={`transition-delay: ${i * 50}ms`}
              >
                <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:items-center">
                  <div class="md:col-span-2">
                    <p class="text-mono text-sm text-[var(--color-fg-subtle)]">
                      {formatDate(post.publishedAt)}
                    </p>
                  </div>
                  <div class="md:col-span-8">
                    <h2 class="text-lg font-semibold text-white transition-colors group-hover:text-[var(--color-accent)]">
                      {post.title}
                    </h2>
                    <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
                      {post.description}
                    </p>
                    {post.tags.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-1.5">
                        {post.tags.slice(0, 3).map((t: string) => (
                          <span class="tag">{t}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="md:col-span-2 md:text-right">
                    <span class="text-sm text-[var(--color-fg-muted)] transition-colors group-hover:text-white">
                      Read →
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
