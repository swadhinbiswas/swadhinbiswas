---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
import { env } from "../lib/env";
import JsonLd from "../components/seo/JsonLd.astro";

import Hero from "../components/home/Hero.astro";
import Impact from "../components/home/Impact.astro";
import Summary from "../components/home/Summary.astro";
import Timeline from "../components/home/Timeline.astro";
import Experience from "../components/home/Experience.astro";
import Skills from "../components/home/Skills.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Research from "../components/home/Research.astro";
import OpenSource from "../components/home/OpenSource.astro";
import Writing from "../components/home/Writing.astro";
import Contact from "../components/home/Contact.astro";

const siteConfig = await getDynamicConfig();
const siteUrl = (siteConfig.url || env.siteUrl || Astro.url.origin).replace(/\/$/, "");
const author = siteConfig.author || env.siteName;
const siteDescription = siteConfig.description || env.siteDescription;
const shortBio = siteConfig.bio?.short?.trim() || "";

const locationText = siteConfig.location || "";
const [cityPart, ...countryParts] = locationText
  .split(",")
  .map((p) => p.trim())
  .filter(Boolean);

const sameAs = [
  siteConfig.links?.github,
  siteConfig.links?.linkedin,
  siteConfig.links?.twitter,
  siteConfig.links?.youtube,
  ...(siteConfig.socials || []).map((s) => s.url),
].filter((u, i, arr): u is string => Boolean(u) && arr.indexOf(u) === i);

const personSchema: Record<string, unknown> = {
  "@type": "Person",
  "@id": `${siteUrl}/#person`,
  name: author,
  url: `${siteUrl}/`,
  image: `${siteUrl}/og-image.png`,
  description: siteDescription,
  sameAs,
  address: cityPart
    ? { "@type": "PostalAddress", addressLocality: cityPart, addressCountry: countryParts.join(", ") || "" }
    : undefined,
  email: siteConfig.email,
  knowsAbout: siteConfig.skills || [],
};
if (shortBio) personSchema.jobTitle = shortBio;
if (siteConfig.seo?.worksFor?.name) {
  personSchema.worksFor = {
    "@type": "Organization",
    name: siteConfig.seo.worksFor.name,
    url: siteConfig.seo.worksFor.url || undefined,
  };
}

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: author,
      description: siteDescription,
      inLanguage: "en-US",
    },
    personSchema,
  ],
};
---

<BaseLayout
  title={undefined}
  description={siteDescription}
  ogType="profile"
>
  <JsonLd slot="head" schema={schema} />

  <Hero />
  <Impact />
  <Summary />
  <Timeline />
  <Experience />
  <Skills />
  <FeaturedProjects />
  <Research />
  <OpenSource />
  <Writing />
  <Contact />
</BaseLayout>
