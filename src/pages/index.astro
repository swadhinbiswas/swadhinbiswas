---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.tsx";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import BentoGrid from "../components/home/BentoGrid.astro";
import { getDynamicConfig } from "../lib/config";
import JsonLd from "../components/seo/JsonLd.astro";

const siteConfig = await getDynamicConfig();

const siteUrl = (siteConfig.url || Astro.url.origin).replace(/\/$/, "");
const personName = siteConfig.author || "Swadhin Biswas";
const shortBio =
  siteConfig.bio?.short?.trim() ||
  "Backend Engineer & AI Systems Architect based in Dhaka, Bangladesh.";
const pageDescription = siteConfig.description?.trim() || shortBio;
const primaryImageUrl = `${siteUrl}/og-image.png`;

const locationText = siteConfig.location || "Dhaka, Bangladesh";
const [cityPart, ...countryParts] = locationText
  .split(",")
  .map((part) => part.trim())
  .filter(Boolean);

const locationCity = cityPart || "Dhaka";
const locationCountry = countryParts.join(", ") || "Bangladesh";

const sameAs = [
  siteConfig.links?.github,
  siteConfig.links?.linkedin,
  siteConfig.links?.twitter,
  ...siteConfig.socials.map((social) => social.url),
  "https://scholar.google.com/citations?hl=en&user=xHqlwTAAAAAJ",
].filter((url, index, urls): url is string => {
  return Boolean(url) && urls.indexOf(url) === index;
});

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: siteConfig.name || personName,
      description: pageDescription,
      inLanguage: "en-US",
      publisher: {
        "@id": `${siteUrl}/#person`,
      },
    },
    {
      "@type": "ProfilePage",
      "@id": `${siteUrl}/#webpage`,
      url: `${siteUrl}/`,
      name: `${personName} | ${siteConfig.name || "Portfolio"}`,
      description: shortBio,
      isPartOf: {
        "@id": `${siteUrl}/#website`,
      },
      about: {
        "@id": `${siteUrl}/#person`,
      },
      primaryImageOfPage: {
        "@id": `${siteUrl}/#primaryimage`,
      },
      inLanguage: "en-US",
    },
    {
      "@type": "ImageObject",
      "@id": `${siteUrl}/#primaryimage`,
      url: primaryImageUrl,
      contentUrl: primaryImageUrl,
      caption: personName,
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: personName,
      url: `${siteUrl}/`,
      image: {
        "@id": `${siteUrl}/#primaryimage`,
      },
      description: shortBio,
      jobTitle: "Backend Engineer & AI Systems Architect",
      sameAs,
      knowsAbout: siteConfig.skills,
      address: {
        "@type": "PostalAddress",
        addressLocality: locationCity,
        addressCountry: locationCountry,
      },
      email: siteConfig.email,
      mainEntityOfPage: {
        "@id": `${siteUrl}/#webpage`,
      },
    },
  ],
};
---

<BaseLayout title="Home" description={pageDescription} ogType="profile">
  <JsonLd slot="head" schema={homeSchema} />
  <Fragment slot="head">
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
  </Fragment>
  <div class="space-y-16 animate-fade-in">
    <!-- Hero Section -->
    <Hero config={siteConfig} />

    <!-- Featured Projects -->
    <FeaturedProjects />

    <!-- Bento Dashboard Grid -->
    <BentoGrid />
  </div>
</BaseLayout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  .animate-fade-in > * {
    animation: fadeIn 0.5s ease-out;
    animation-fill-mode: both;
  }

  .animate-fade-in > *:nth-child(1) {
    animation-delay: 0.1s;
  }
  .animate-fade-in > *:nth-child(2) {
    animation-delay: 0.2s;
  }
  .animate-fade-in > *:nth-child(3) {
    animation-delay: 0.3s;
  }
  .animate-fade-in > *:nth-child(4) {
    animation-delay: 0.4s;
  }
</style>
