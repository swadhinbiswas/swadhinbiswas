---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
import { db, skills, projects } from "../db";
import { asc } from "drizzle-orm";

const siteConfig = await getDynamicConfig();
const author = siteConfig.author || "Swadhin Biswas";

interface Skill {
  id: number;
  name: string;
  category?: string;
  description?: string;
  usedIn?: string;
  tier?: string;
}

interface Project {
  id: number;
  name: string;
  tags: string;
}

let all: Skill[] = [];
let allProjects: Project[] = [];

try {
  const rows = await db.select().from(skills).orderBy(asc(skills.order));
  all = rows as Skill[];
} catch {
  all = [];
}

try {
  const projRows = await db.select().from(projects);
  allProjects = projRows as Project[];
} catch {
  allProjects = [];
}

function safeJSON(s: any): string[] {
  try { return JSON.parse(s); } catch { return []; }
}

const projectTagsMap = new Map<string, string[]>();
for (const proj of allProjects) {
  const tags = safeJSON(proj.tags);
  if (tags.length > 0) {
    projectTagsMap.set(proj.name.toLowerCase(), tags);
  }
}

const skillToProjects = new Map<string, string[]>();
for (const [projName, tags] of projectTagsMap) {
  for (const tag of tags) {
    const normalized = tag.toLowerCase();
    const existing = skillToProjects.get(normalized) || [];
    if (!existing.includes(projName)) {
      existing.push(projName);
      skillToProjects.set(normalized, existing);
    }
  }
}

for (const skill of all) {
  const key = skill.name.toLowerCase();
  if (!skill.usedIn) {
    const linkedProjects = skillToProjects.get(key) || [];
    if (linkedProjects.length > 0) {
      skill.usedIn = JSON.stringify(linkedProjects);
    }
  }
}

const skilliconsMap: Record<string, string> = {
  "python": "python",
  "rust": "rust",
  "go": "go",
  "typescript": "ts",
  "javascript": "js",
  "django": "django",
  "fastapi": "fastapi",
  "react": "react",
  "next.js": "nextjs",
  "nextjs": "nextjs",
  "astro": "astro",
  "vue.js": "vuejs",
  "vuejs": "vuejs",
  "node.js": "nodejs",
  "nodejs": "nodejs",
  "docker": "docker",
  "kubernetes": "kubernetes",
  "terraform": "terraform",
  "ansible": "ansible",
  "github actions": "githubactions",
  "nginx": "nginx",
  "prometheus": "prometheus",
  "grafana": "grafana",
  "postgresql": "postgresql",
  "postgres": "postgresql",
  "mysql": "mysql",
  "sqlite": "sqlite",
  "duckdb": "duckdb",
  "redis": "redis",
  "mongodb": "mongodb",
  "pinecone": "pinecone",
  "qdrant": "qdrant",
  "weaviate": "weaviate",
  "chroma": "chroma",
  "clickhouse": "clickhouse",
  "timescaledb": "timescaledb",
  "kafka": "kafka",
  "apache airflow": "airflow",
  "airflow": "airflow",
  "apache spark": "spark",
  "spark": "spark",
  "apache flink": "flink",
  "flink": "flink",
  "dbt": "dbt",
  "mage": "mage",
  "prefect": "prefect",
  "machine learning": "tensorflow",
  "deep learning": "pytorch",
  "pytorch": "pytorch",
  "tensorflow": "tensorflow",
  "nlp": "huggingface",
  "hugging face": "huggingface",
  "computer vision": "opencv",
  "langchain": "langchain",
  "openai api": "openai",
  "git": "git",
  "linux": "linux",
  "neovim": "neovim",
  "mojo": "mojo",
  "sql": "mysql",
};

const deviconsFallback: Record<string, string> = {
  "python": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg",
  "rust": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/rust/rust-original.svg",
  "go": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/go/go-original.svg",
  "typescript": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
  "javascript": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
  "django": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/django/django-plain.svg",
  "react": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
  "docker": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg",
  "kubernetes": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kubernetes/kubernetes-plain.svg",
  "postgresql": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg",
  "redis": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/redis/redis-original.svg",
  "mongodb": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg",
  "kafka": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/apachekafka/apachekafka-original.svg",
  "node.js": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg",
  "express": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/express/express-original.svg",
  "vue.js": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg",
  "astro": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg",
  "terraform": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/terraform/terraform-original.svg",
  "ansible": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ansible/ansible-original.svg",
  "nginx": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nginx/nginx-original.svg",
  "git": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg",
  "neovim": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/neovim/neovim-original.svg",
  "mysql": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
  "sqlite": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sqlite/sqlite-original.svg",
  "pytorch": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/pytorch/pytorch-original.svg",
  "tensorflow": "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tensorflow/tensorflow-original.svg",
};

function iconFor(name: string): { type: "skillicons" | "devicon"; src: string } | null {
  const key = name.toLowerCase();
  if (skilliconsMap[key]) {
    return { type: "skillicons", src: `https://skillicons.dev/icons?i=${skilliconsMap[key]}&theme=dark` };
  }
  if (deviconsFallback[key]) {
    return { type: "devicon", src: deviconsFallback[key] };
  }
  return null;
}

function initials(name: string) {
  return name
    .replace(/[^a-zA-Z0-9+#.]/g, "")
    .slice(0, 3)
    .toUpperCase();
}

const grouped = all.reduce<Record<string, Skill[]>>((acc, skill) => {
  const category = skill.category || "general";
  acc[category] = acc[category] || [];
  acc[category].push(skill);
  return acc;
}, {});

const categoryOrder: Record<string, number> = {
  "language": 1,
  "framework": 2,
  "data engineering": 3,
  "database": 4,
  "devops": 5,
  "ai": 6,
  "general": 7,
};

const sortedCategories = Object.entries(grouped).sort(
  ([a], [b]) => (categoryOrder[a] || 99) - (categoryOrder[b] || 99)
);

const categoryLabel = (category: string) =>
  category
    .split(/[-_\s]+/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const categoryIcons: Record<string, string> = {
  "language": "code",
  "framework": "layers",
  "data engineering": "database",
  "database": "server",
  "devops": "settings",
  "ai": "cpu",
  "general": "tool",
};
---

<BaseLayout title="Skills" description={`Technologies and tools ${author} uses to build production systems.`}>
  <section class="skills-page">
    <div class="container-narrow py-10 sm:py-14">
      <div class="reveal">
        <p class="text-eyebrow">Skills & Stack</p>
        <h1 class="text-display mt-3 text-3xl sm:text-4xl">
          <span class="text-gradient">Technologies I Use</span>
        </h1>
        <p class="mt-4 text-base text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
          Every skill here is linked to real projects. When I add a project with tags, those skills automatically appear with context on where they were used.
        </p>
      </div>

      {all.length === 0 ? (
        <p class="portfolio-card p-6 text-sm text-[var(--color-fg-muted)] mt-8 reveal">
          Skills will appear here once added from the admin panel.
        </p>
      ) : (
        <div class="mt-10 space-y-8">
          {sortedCategories.map(([category, skills]) => (
            <div class="reveal">
              <div class="flex items-center gap-3 mb-4">
                <div class="category-icon-badge">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    {category === "language" && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                    {category === "framework" && <><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></>}
                    {category === "data engineering" && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                    {category === "database" && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                    {category === "devops" && <><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></>}
                    {category === "ai" && <><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></>}
                    {category === "general" && <><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></>}
                  </svg>
                </div>
                <h2 class="text-lg font-bold text-[var(--color-fg)]">{categoryLabel(category)}</h2>
                <span class="text-mono text-xs text-[var(--color-fg-subtle)] ml-1">{skills.length} {skills.length === 1 ? "tool" : "tools"}</span>
              </div>

              <div class="skills-grid">
                {skills.map((s) => {
                  const icon = iconFor(s.name);
                  const linkedProjects = s.usedIn ? safeJSON(s.usedIn) : (skillToProjects.get(s.name.toLowerCase()) || []);
                  const isCore = s.tier === 'core';
                  return (
                    <div class:list={["skill-card group", isCore && "skill-card-core"]}>
                      <div class="skill-card-header">
                        <div class="skill-icon-wrap">
                          {icon ? (
                            <img src={icon.src} alt={s.name} loading="lazy" class="skill-icon" />
                          ) : (
                            <span class="skill-initials">{initials(s.name)}</span>
                          )}
                        </div>
                        <div class="skill-card-info">
                          <div class="flex items-center gap-2">
                            <h3 class="skill-name">{s.name}</h3>
                            {isCore && <span class="text-[9px] font-mono uppercase tracking-wider text-[var(--color-accent)] bg-[rgba(124,58,237,0.15)] px-1.5 py-0.5 rounded">Core</span>}
                          </div>
                          {s.description && (
                            <p class="skill-desc">{s.description}</p>
                          )}
                        </div>
                      </div>
                      {linkedProjects.length > 0 && (
                        <div class="skill-projects">
                          <span class="skill-projects-label">Used in</span>
                          <div class="skill-project-tags">
                            {linkedProjects.map((p: string) => (
                              <span class="skill-project-tag">{p}</span>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .skills-page {
    min-height: 60vh;
  }

  .category-icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));
    color: #fff;
    flex-shrink: 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.75rem;
  }

  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid var(--color-edge);
    background: var(--color-card);
    transition: all 0.25s ease;
  }

  .skill-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.1);
    transform: translateY(-1px);
  }

  .skill-card-core {
    border-color: rgba(124, 58, 237, 0.3);
    background: rgba(124, 58, 237, 0.05);
  }

  .skill-card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .skill-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 10px;
    background: var(--color-card-strong);
    border: 1px solid var(--color-edge);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .skill-card:hover .skill-icon-wrap {
    border-color: var(--color-accent);
    transform: scale(1.05);
  }

  .skill-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    filter: brightness(1.1);
  }

  .skill-initials {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .skill-card-info {
    min-width: 0;
    flex: 1;
  }

  .skill-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.3;
  }

  .skill-desc {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }

  .skill-projects {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-edge);
  }

  .skill-projects-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .skill-project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .skill-project-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--color-fg-subtle);
    background: rgba(124, 58, 237, 0.08);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .skill-project-tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(124, 58, 237, 0.15);
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>