---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
const siteConfig = await getDynamicConfig();

const socials = siteConfig.socials;
---

<BaseLayout title="Contact">
  <div class="animate-fade-in max-w-5xl mx-auto">

    <!-- Page Header -->
    <div class="mb-16 pb-8 border-b border-glass-border">
      <p class="text-xs font-mono text-overlay0 mb-3">~/contact</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-mono tracking-tight text-text mb-4">
        Get in <span class="text-accent">Touch</span>
      </h1>
      <p class="text-lg font-serif text-subtext0 max-w-2xl leading-relaxed italic">
        Have a project idea, research collaboration, or just want to chat about systems design? I'd love to hear from you.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

      <!-- Terminal Contact Form -->
      <div class="lg:col-span-3">
        <div class="rounded-xl overflow-hidden border border-surface0/50 bg-mantle">
          <!-- Terminal Title Bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-surface0/30 border-b border-surface0/50">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow/60"></div>
              <div class="w-3 h-3 rounded-full bg-green/60"></div>
            </div>
            <span class="text-xs font-mono text-overlay0 ml-2">contact-form.sh</span>
          </div>

          <!-- Terminal Body -->
          <form id="contact-form" class="p-6 space-y-5 font-mono text-sm">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs text-overlay0 mb-2">
                  $ name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="terminal-input w-full"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-xs text-overlay0 mb-2">
                  $ email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="terminal-input w-full"
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-xs text-overlay0 mb-2">
                $ subject
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="terminal-input w-full"
                placeholder="Project Collaboration"
              />
            </div>

            <div>
              <label for="message" class="block text-xs text-overlay0 mb-2">
                $ message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="terminal-input w-full resize-none"
                placeholder="Tell me about your project or idea..."
              ></textarea>
            </div>

            <!-- Honeypot (anti-spam) -->
            <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

            <button
              type="submit"
              class="w-full sm:w-auto px-6 py-2.5 bg-accent/10 border border-accent/30 text-accent font-mono text-sm font-bold rounded-lg hover:bg-accent/20 hover:border-accent/50 transition-all flex items-center justify-center gap-2"
            >
              <span class="text-accent">></span>
              <span>send_message</span>
              <span class="animate-pulse">_</span>
            </button>
          </form>
        </div>

        <!-- Form Status -->
        <div id="form-status" class="hidden mt-4 p-4 rounded-xl font-mono text-sm"></div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Direct Contact -->
        <div class="academic-card">
          <h3 class="text-sm font-mono text-text mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Direct Contact
          </h3>
          <dl class="space-y-3 text-sm font-mono">
            <div>
              <dt class="text-xs text-overlay0 mb-1">Email</dt>
              <dd><a href={`mailto:${siteConfig.email}`} class="text-accent hover:underline text-sm">{siteConfig.email}</a></dd>
            </div>
            <div>
              <dt class="text-xs text-overlay0 mb-1">Location</dt>
              <dd class="text-text text-sm">{siteConfig.location}</dd>
            </div>
            <div>
              <dt class="text-xs text-overlay0 mb-1">Timezone</dt>
              <dd class="text-text text-sm">{siteConfig.timezone}</dd>
            </div>
            <div>
              <dt class="text-xs text-overlay0 mb-1">Response Time</dt>
              <dd class="text-green text-sm">Usually within 24 hours</dd>
            </div>
          </dl>
        </div>

        <!-- Social Links -->
        <div class="academic-card">
          <h3 class="text-sm font-mono text-text mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-mauve" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Find Me Online
          </h3>
          <div class="space-y-1">
            {socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-2 -mx-2 rounded-lg hover:bg-surface0/30 text-subtext0 hover:text-accent transition-colors text-sm"
              >
                {social.icon === "github" && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
                )}
                {social.icon === "linkedin" && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" /></svg>
                )}
                {social.icon === "twitter" && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
                )}
                {social.icon === "youtube" && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
                )}
                {social.icon === "email" && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                )}
                <span class="text-sm">{social.name}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Availability -->
        <div class="bg-gradient-to-br from-green/10 to-teal/10 border border-green/20 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green"></span>
            </span>
            <h3 class="text-sm font-mono text-text font-semibold">Available for Work</h3>
          </div>
          <p class="text-xs text-subtext0 leading-relaxed">
            Currently accepting new projects, research collaborations, and consulting opportunities.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot && honeypot.value) return;

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalBtnText = submitBtn ? submitBtn.innerHTML : "";

    if (submitBtn) {
      submitBtn.innerHTML = `<span class="text-accent">></span><span>sending...</span><span class="animate-pulse">_</span>`;
      (submitBtn as HTMLButtonElement).disabled = true;
    }

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (status) {
        status.classList.remove("hidden");
        if (response.ok) {
          status.className = "mt-4 p-4 rounded-xl bg-green/10 border border-green/20 text-green font-mono text-sm";
          status.innerHTML = `<div class="flex items-center gap-2"><span class="text-green">✓</span><span>Message sent! I'll get back to you soon.</span></div>`;
          form.reset();
        } else {
          throw new Error(result.error || "Failed");
        }
      }
    } catch (error) {
      if (status) {
        status.classList.remove("hidden");
        status.className = "mt-4 p-4 rounded-xl bg-red/10 border border-red/20 text-red font-mono text-sm";
        status.innerHTML = `<div class="flex items-center gap-2"><span class="text-red">✗</span><span>Failed: ${error instanceof Error ? error.message : "Server error"}</span></div>`;
      }
    } finally {
      if (submitBtn) {
        submitBtn.innerHTML = originalBtnText;
        (submitBtn as HTMLButtonElement).disabled = false;
      }
      setTimeout(() => {
        if (status) status.classList.add("hidden");
      }, 8000);
    }
  });
</script>
