---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";

const siteConfig = await getDynamicConfig();
const email = siteConfig.email || "";
const socials = (siteConfig.socials || []).filter((s) =>
  ["github", "linkedin", "twitter", "youtube", "scholar"].includes(s.icon)
);
---

<BaseLayout title="Contact" description="Get in touch — open to senior data, ML, and platform engineering roles, consulting, and research collaboration.">
  <section class="section">
    <div class="container-page">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12">
        <div class="lg:col-span-5 reveal">
          <p class="section-eyebrow">Contact</p>
          <h1 class="section-title mt-3">Let's talk.</h1>
          <p class="mt-6 text-lg leading-relaxed text-[var(--color-fg-muted)]">
            Open to full-time roles, consulting, research collaboration, and advisory work in data, ML, and platform engineering.
          </p>

          <div class="mt-10 space-y-5">
            <div>
              <p class="text-eyebrow">Email</p>
              <a href={`mailto:${email}`} class="mt-1.5 inline-block text-base text-white hover:underline">
                {email}
              </a>
            </div>

            {siteConfig.location && (
              <div>
                <p class="text-eyebrow">Location</p>
                <p class="mt-1.5 text-base text-white">{siteConfig.location}</p>
              </div>
            )}

            <div>
              <p class="text-eyebrow">Response time</p>
              <p class="mt-1.5 inline-flex items-center gap-2 text-base text-white">
                <span class="relative inline-flex h-2 w-2">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-success)] opacity-60"></span>
                  <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-success)]"></span>
                </span>
                Within 24 hours
              </p>
            </div>
          </div>

          {socials.length > 0 && (
            <div class="mt-10">
              <p class="text-eyebrow">Elsewhere</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {socials.map((s) => (
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] px-3.5 py-1.5 text-sm text-[var(--color-fg-muted)] transition-colors hover:border-[var(--color-fg-subtle)] hover:text-white"
                  >
                    {s.icon === "github" && <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>}
                    {s.icon === "linkedin" && <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>}
                    {s.icon === "twitter" && <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
                    {s.icon === "youtube" && <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
                    {s.icon === "scholar" && <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>}
                    {s.name}
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="mt-10 card p-5">
            <p class="text-eyebrow">Currently open to</p>
            <ul class="mt-3 space-y-2 text-sm text-white">
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-success)]">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                Full-time roles
              </li>
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-success)]">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                Remote / Hybrid
              </li>
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-success)]">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                Consulting / Advisory
              </li>
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-[var(--color-success)]">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                Research collaboration
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-7 reveal reveal-delay-1">
          <form id="contact-form" class="card p-6 sm:p-10 space-y-5">
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="text-eyebrow block">Name</label>
                <input type="text" id="name" name="name" required class="form-input mt-2" placeholder="Your name" />
              </div>
              <div>
                <label for="email" class="text-eyebrow block">Email</label>
                <input type="email" id="email" name="email" required class="form-input mt-2" placeholder="you@example.com" />
              </div>
            </div>

            <div>
              <label for="subject" class="text-eyebrow block">Subject</label>
              <input type="text" id="subject" name="subject" required class="form-input mt-2" placeholder="Project collaboration" />
            </div>

            <div>
              <label for="message" class="text-eyebrow block">Message</label>
              <textarea id="message" name="message" rows="6" required class="form-input mt-2 resize-none" placeholder="Tell me about your project or idea..."></textarea>
            </div>

            <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
              <p class="text-xs text-[var(--color-fg-subtle)]">All fields are required.</p>
              <button type="submit" class="btn btn-primary">
                Send message
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/>
                </svg>
              </button>
            </div>

            <div id="form-status" class="hidden mt-4 p-4 rounded-md text-sm"></div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .form-input {
    width: 100%;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    color: var(--color-fg);
    font-size: 0.9375rem;
    transition: border-color 0.2s, background-color 0.2s;
    font-family: var(--font-sans);
  }
  .form-input::placeholder { color: var(--color-fg-subtle); }
  .form-input:focus {
    outline: none;
    border-color: var(--color-fg-subtle);
    background-color: var(--color-surface);
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const original = submitBtn.innerHTML;
    submitBtn.innerHTML = `<span>Sending...</span>`;
    submitBtn.disabled = true;

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const result = await res.json();

      if (status) {
        status.classList.remove("hidden");
        if (res.ok) {
          status.className = "mt-4 p-4 rounded-md bg-[var(--color-success)]/10 border border-[var(--color-success)]/30 text-[var(--color-success)] text-sm";
          status.textContent = "✓ Message sent. I'll get back to you within 24 hours.";
          form.reset();
        } else {
          throw new Error(result.error || "Failed");
        }
      }
    } catch (err) {
      if (status) {
        status.classList.remove("hidden");
        status.className = "mt-4 p-4 rounded-md bg-[var(--color-danger)]/10 border border-[var(--color-danger)]/30 text-[var(--color-danger)] text-sm";
        status.textContent = "✗ Something went wrong. Please email me directly.";
      }
    } finally {
      submitBtn.innerHTML = original;
      submitBtn.disabled = false;
      setTimeout(() => status?.classList.add("hidden"), 8000);
    }
  });
</script>
