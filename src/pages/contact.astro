---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getDynamicConfig } from "../lib/config";
import { env } from "../lib/env";

const siteConfig = await getDynamicConfig();
const email = siteConfig.email || env.email;
const socials = (siteConfig.socials || []).filter((s) =>
  ["github", "linkedin", "twitter", "youtube", "scholar"].includes(s.icon)
);
---

<BaseLayout title="Contact" description={siteConfig.description || env.siteDescription}>
  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <div class="reveal">
        <p class="text-eyebrow">Contact</p>
        <h1 class="text-display mt-3 text-3xl sm:text-4xl text-gradient">Get in touch</h1>
        <p class="prose-mono mt-4 max-w-prose">
          Best way to reach me is email — for anything from collaboration to a quick question.
        </p>
      </div>
    </div>
  </section>

  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
        <div class="md:col-span-3 reveal">
          <p class="text-eyebrow">Email</p>
        </div>
        <div class="md:col-span-9 reveal reveal-delay-1">
          {email ? (
            <a
              href={`mailto:${email}`}
              class="text-mono break-all text-base text-[var(--color-accent)] transition-colors hover:text-[var(--color-fg-muted)]"
            >
              {email} →
            </a>
          ) : (
            <p class="prose-mono italic">No email configured yet.</p>
          )}
          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-mono text-xs text-[var(--color-fg-subtle)]">
            {siteConfig.location && <span>{siteConfig.location}</span>}
            {siteConfig.timezone && <span>· {siteConfig.timezone}</span>}
          </div>
          <p class="mt-3 text-xs text-[var(--color-fg-subtle)]">
            <span class="text-[var(--color-accent)]">●</span> Available 8am–12pm CET daily for calls
          </p>
        </div>
      </div>
    </div>
  </section>

  {socials.length > 0 && (
    <section class="screen-line-after">
      <div class="container-narrow py-12 sm:py-16">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
          <div class="md:col-span-3 reveal">
            <p class="text-eyebrow">Elsewhere</p>
          </div>
          <div class="md:col-span-9 reveal reveal-delay-1">
            <div class="flex flex-wrap gap-x-5 gap-y-2 text-mono text-sm">
              {socials.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--color-accent)] transition-colors hover:text-[var(--color-fg-muted)]"
                >
                  {s.name} →
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="screen-line-after">
    <div class="container-narrow py-12 sm:py-16">
      <p class="text-eyebrow reveal">Or send a message</p>
      <form id="contact-form" class="mt-6 space-y-5 reveal reveal-delay-1">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="text-eyebrow block">Name</label>
            <input type="text" id="name" name="name" required class="form-input mt-2" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="text-eyebrow block">Email</label>
            <input type="email" id="email" name="email" required class="form-input mt-2" placeholder="you@example.com" />
          </div>
        </div>

        <div>
          <label for="subject" class="text-eyebrow block">Subject</label>
          <input type="text" id="subject" name="subject" required class="form-input mt-2" placeholder="Project collaboration" />
        </div>

        <div>
          <label for="message" class="text-eyebrow block">Message</label>
          <textarea id="message" name="message" rows="6" required class="form-input mt-2 resize-none" placeholder="Tell me about your project or idea..."></textarea>
        </div>

        <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
          <p class="text-xs text-[var(--color-fg-subtle)]">All fields are required.</p>
          <button type="submit" class="btn btn-primary">
            Send message
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/>
            </svg>
          </button>
        </div>

        <div id="form-status" class="hidden mt-4 p-4 rounded-md text-sm"></div>
      </form>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .form-input {
    width: 100%;
    background-color: var(--color-card);
    border: 2px solid var(--color-edge);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    color: var(--color-fg);
    font-size: 0.9375rem;
    transition: all 0.25s ease;
    font-family: var(--font-sans);
    box-shadow: 0 2px 8px rgba(199, 146, 234, 0.04);
  }
  .form-input::placeholder { color: var(--color-fg-subtle); }
  .form-input:hover {
    border-color: var(--color-accent-2);
  }
  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(199, 146, 234, 0.25), 0 4px 12px rgba(199, 146, 234, 0.1);
    background-color: var(--color-bg);
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const original = submitBtn.innerHTML;
    submitBtn.innerHTML = `<span>Sending...</span>`;
    submitBtn.disabled = true;

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const result = await res.json();

      if (status) {
        status.classList.remove("hidden");
        if (res.ok) {
          status.className = "mt-4 p-4 rounded-md bg-[var(--color-success)]/10 border border-[var(--color-success)]/30 text-[var(--color-success)] text-sm";
          status.textContent = "✓ Message sent. I'll get back to you within 24 hours.";
          form.reset();
        } else {
          throw new Error(result.error || "Failed");
        }
      }
    } catch (err) {
      if (status) {
        status.classList.remove("hidden");
        status.className = "mt-4 p-4 rounded-md bg-[var(--color-danger)]/10 border border-[var(--color-danger)]/30 text-[var(--color-danger)] text-sm";
        status.textContent = "✗ Something went wrong. Please email me directly.";
      }
    } finally {
      submitBtn.innerHTML = original;
      submitBtn.disabled = false;
      setTimeout(() => status?.classList.add("hidden"), 8000);
    }
  });
</script>
