---
import { db, projects } from "../../db";
import { desc, eq, asc } from "drizzle-orm";

interface Project {
  id: number | string;
  name: string;
  description: string;
  url: string;
  github?: string | null;
  tags: string[];
  featured?: boolean;
  stars?: number;
  order?: number;
}

let allProjects: Project[] = [];
try {
  const rows = await db
    .select()
    .from(projects)
    .orderBy(asc(projects.order), desc(projects.stars));

  allProjects = rows.map((r) => ({
    ...r,
    tags: safeJSON(r.tags) as string[],
  })) as Project[];
} catch {
  allProjects = [];
}

function safeJSON(s: any): string[] {
  try {
    return JSON.parse(s);
  } catch {
    return [];
  }
}

function slug(name: string) {
  return name
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, "")
    .replace(/[\s_-]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const visible = allProjects.slice(0, 6);
---

<section class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="mb-6 flex items-baseline justify-between reveal">
      <h2 class="panel-title">
        Projects<span class="count-badge">{allProjects.length || ""}</span>
      </h2>
      <a href="/projects" class="text-mono text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-white">
        View all →
      </a>
    </div>

    {allProjects.length === 0 ? (
      <p class="text-sm text-[var(--color-fg-muted)] reveal">
        No projects yet. Add them from the admin panel.
      </p>
    ) : (
      <div class="panel">
        <div class="panel-top"></div>
        {visible.map((p) => (
          <a href={`/projects/${slug(p.name)}`} class="row-card group">
            <div class="row-card-logo" aria-hidden="true">
              {p.name.charAt(0).toUpperCase()}
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="row-card-title">
                {p.name}
                {p.featured && (
                  <span class="ml-1.5 text-[var(--color-fg-subtle)]">★</span>
                )}
              </h3>
              {p.description && (
                <p class="prose-mono mt-1 line-clamp-2">{p.description}</p>
              )}
              {p.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {p.tags.slice(0, 5).map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              )}
            </div>

            <div class="row-card-actions">
              {p.stars != null && p.stars > 0 && (
                <span class="text-mono text-[10px] text-[var(--color-fg-subtle)]">
                  ★ {p.stars.toLocaleString()}
                </span>
              )}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                <path d="M5 12h14M13 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
        <div class="panel-bottom"></div>
      </div>
    )}
  </div>
</section>
