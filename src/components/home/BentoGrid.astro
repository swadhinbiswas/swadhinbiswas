---
import LocationMap from "./bento/LocationMap.astro";
import Clicker from "./bento/Clicker.astro";
import {
  db,
  siteSettings,
  experiences,
  projects,
  publications,
  pageViews,
  bioContent,
} from "../../db";

const [settingsRows, experienceRows, projectRows, publicationRows, pageViewRows, bioRows] = await Promise.all([
  db.select().from(siteSettings),
  db.select().from(experiences).orderBy(experiences.order),
  db.select().from(projects).orderBy(projects.order),
  db.select().from(publications).orderBy(publications.order),
  db.select().from(pageViews),
  db.select().from(bioContent),
]);

const settings = Object.fromEntries(settingsRows.map((row) => [row.key, row.value]));
const bio = Object.fromEntries(bioRows.map((row) => [row.key, row.value]));

const descriptionParts = String(settings.site_description || "")
  .split("|")
  .map((part) => part.trim())
  .filter(Boolean);

const currentRole = settings.current_role || descriptionParts[0] || settings.seo_title || "Indie Engineer";
const currentFocus = descriptionParts[1] || "AI Systems Architect";
const currentDescriptor = descriptionParts[2] || "Data Science Enthusiast";
const currentCompany = settings.works_for_name || "Self-Employed";
const currentLocation = settings.location || "Dhaka, Bangladesh";
const currentTimezone = settings.timezone || "Asia/Dhaka";

const careerSummary = (() => {
  const source = bio.long || bio.short || settings.site_description || "";
  const sentences = source
    .split(/\.\s+/)
    .map((sentence) => sentence.trim())
    .filter(Boolean);

  if (sentences.length <= 2) return source;
  return `${sentences.slice(0, 2).join(". ")}.`;
})();

const earliestExperience = experienceRows.length
  ? experienceRows.slice().sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime())[0]
  : null;

const experienceYears = earliestExperience
  ? Math.max(1, new Date().getFullYear() - new Date(earliestExperience.startDate).getFullYear())
  : 0;

const featuredProjects = projectRows.filter((project) => project.featured);
const totalProjectStars = featuredProjects.reduce((sum, project) => sum + (project.stars ?? 0), 0);
const latestPublication = publicationRows[0];
const pageViewCount = pageViewRows[0]?.count ?? 0;
const reachLabel = pageViewCount >= 1000000
  ? `${(pageViewCount / 1000000).toFixed(pageViewCount >= 10000000 ? 0 : 1)}M+`
  : pageViewCount.toLocaleString();

const recruiterMetrics = [
  {
    label: "Current Role",
    value: currentRole,
    detail: `${currentFocus} @ ${currentCompany}`,
    accent: "text-blue",
    dot: "bg-blue",
  },
  {
    label: "Experience",
    value: `${experienceYears}+ yrs`,
    detail: earliestExperience ? `Since ${new Date(earliestExperience.startDate).getFullYear()}` : "Hands-on delivery",
    accent: "text-sky",
    dot: "bg-sky",
  },
  {
    label: "Location",
    value: currentLocation,
    detail: currentTimezone,
    accent: "text-mauve",
    dot: "bg-mauve",
  },
  {
    label: "Featured Projects",
    value: `${featuredProjects.length}`,
    detail: `${totalProjectStars} total stars`,
    accent: "text-green-400",
    dot: "bg-green-400",
  },
  {
    label: "Publications",
    value: `${publicationRows.length}`,
    detail: latestPublication?.venue || latestPublication?.title || "Research-ready",
    accent: "text-blue",
    dot: "bg-blue",
  },
];

const signalPills = [
  `${reachLabel} page views`,
  currentDescriptor,
  `${publicationRows.length} publication${publicationRows.length === 1 ? "" : "s"}`,
];
---

<section id="projects" class="space-y-6 py-12 relative">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold font-mono text-white flex items-center gap-3">
      <span class="text-neon-cyan animate-pulse">●</span>
      <span>SYSTEM_COMMAND_CENTER</span>
    </h2>
    <div class="hidden md:flex gap-4 font-mono text-[9px] text-gray-500 uppercase tracking-widest">
      <span>ENV: PRODUCTION</span>
      <span>|</span>
      <span id="system-uptime">UPTIME: 00:00:00</span>
    </div>
  </div>

  <div class="bento-grid w-full gap-4">
    <!-- Row 1: The Core HUD -->

    <!-- Developer Core OS - High Density -->
    <div class="bento-item bento-metrics glass-panel hud-scan p-4 flex flex-col border-accent/10">
      <div class="flex justify-between items-start mb-4">
        <div>
          <div class="text-[8px] font-mono text-neon-cyan uppercase tracking-widest mb-1">Identity_Kernel</div>
          <div class="text-3xl font-bold text-white font-mono leading-none tracking-tighter" id="dev-score">000</div>
        </div>
        <div id="dev-rank-badge" class="px-2 py-1 bg-electric-purple text-white font-bold text-[10px] font-mono opacity-0 transition-opacity shadow-[0_0_15px_rgba(188,19,254,0.3)]">
          RANK: S+
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4 border-t border-white/5 pt-4">
        <div class="space-y-3">
          <div>
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-1">Nodes_Connected</div>
            <div class="text-sm font-bold text-white font-mono" id="dev-followers">0</div>
          </div>
          <div>
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-1">Stars_Captured</div>
            <div class="text-sm font-bold text-white font-mono" id="dev-stars">0</div>
          </div>
        </div>
        <div class="space-y-3 text-right">
          <div>
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-1">Repositories</div>
            <div class="text-sm font-bold text-white font-mono" id="dev-repos">0</div>
          </div>
          <div>
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-1">Active_Streak</div>
            <div class="text-sm font-bold text-green-400 font-mono" id="dev-streak">0d</div>
          </div>
        </div>
      </div>

      <div class="mt-auto pt-4 border-t border-white/5">
        <div class="flex justify-between items-center text-[8px] font-mono text-gray-500 mb-2">
          <span>CORE_INTEGRITY</span>
          <span id="integrity-val" class="text-neon-cyan">0%</span>
        </div>
        <div class="h-1 bg-white/5 relative overflow-hidden">
          <div id="score-progress" class="absolute top-0 left-0 h-full bg-neon-cyan transition-all duration-1000" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- Activity Matrix - Sparkline Version -->
    <div class="bento-item bento-productivity glass-panel p-4 flex flex-col">
      <div class="flex justify-between items-center mb-4">
        <div class="text-[8px] font-mono text-electric-purple uppercase tracking-widest">Efficiency_Logic</div>
        <span id="velocity-badge" class="text-[8px] font-mono px-1.5 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 opacity-0">
          +0% VEL
        </span>
      </div>

      <div class="flex flex-1 gap-4 items-center">
        <div class="w-20 h-20 flex-shrink-0">
           <svg viewBox="0 0 200 200" class="w-full h-full opacity-80">
              <path id="radar-polygon" d="M100,100 L100,100 L100,100 L100,100 Z" fill="rgba(188, 19, 254, 0.1)" stroke="#bc13fe" stroke-width="2" />
              <circle cx="100" cy="100" r="80" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1" />
           </svg>
        </div>
        <div class="flex-1 grid grid-cols-1 gap-2">
          <div class="bg-white/5 p-2 border-l border-neon-cyan/30">
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-0.5">Intensity</div>
            <div class="text-xs font-bold text-white font-mono" id="metric-intensity">0.0h</div>
          </div>
          <div class="bg-white/5 p-2 border-l border-electric-purple/30">
            <div class="text-[7px] text-gray-500 font-mono uppercase mb-0.5">Focus</div>
            <div class="text-xs font-bold text-white font-mono" id="metric-focus">0%</div>
          </div>
        </div>
      </div>

      <div class="mt-4 flex flex-col gap-1">
        <div class="flex justify-between text-[7px] font-mono text-gray-500 uppercase">
          <span>Neural_Sync</span>
          <span id="metric-top-lang" class="text-neon-cyan">---</span>
        </div>
        <div class="h-0.5 w-full bg-white/5 relative">
          <div id="consistency-bar" class="absolute top-0 left-0 h-full bg-electric-purple transition-all duration-1000" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- System Load Graph - Ultra Refined -->
    <div class="bento-item bento-posts glass-panel p-3 flex flex-col min-h-0">
      <div class="flex justify-between items-center mb-3">
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-blue shadow-[0_0_10px_rgba(137,180,250,0.35)]"></div>
          <h3 class="text-[9px] md:text-[10px] font-mono text-blue font-bold uppercase tracking-widest">Module_Activity_Index</h3>
        </div>
        <div class="flex gap-4">
          <div id="loc-stats" class="text-[8px] font-mono text-gray-500 opacity-0 transition-opacity">
            <span class="text-blue" id="loc-total">0</span> LOC <span class="text-green-500/40">(+<span id="loc-added"></span>)</span>
          </div>
          <div class="text-[8px] font-mono text-gray-500">
            LIFETIME: <span id="total-contributions" class="text-sky font-bold">0</span>
          </div>
        </div>
      </div>
      <div class="w-full relative h-[220px] md:h-[280px] max-w-[760px] mx-auto">
        <canvas id="activityChart"></canvas>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-2 md:flex md:flex-wrap md:gap-3">
        {recruiterMetrics.map((metric) => (
          <div class="flex-1 min-w-[140px] rounded-2xl border border-white/8 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.03))] p-3 md:p-4 min-h-[108px] flex flex-col justify-between backdrop-blur-sm shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
            <div class="flex items-center justify-between gap-2 text-[8px] font-mono uppercase tracking-widest text-gray-500">
              <span>{metric.label}</span>
              <span class={`w-1.5 h-1.5 rounded-full ${metric.dot} shadow-[0_0_8px_currentColor]`}></span>
            </div>
            <div class={`text-lg md:text-2xl font-bold font-mono tracking-tight leading-tight break-words ${metric.accent}`}>
              {metric.value}
            </div>
            <div class="text-[10px] md:text-xs text-subtext1 leading-snug">
              {metric.detail}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-4 rounded-2xl border border-white/8 bg-white/5 p-4 md:p-5 backdrop-blur-sm">
        <div class="flex items-center justify-between gap-2 mb-3">
          <div class="flex items-center gap-2 text-[8px] font-mono uppercase tracking-widest text-gray-500">
            <span class="w-1.5 h-1.5 rounded-full bg-blue shadow-[0_0_10px_rgba(137,180,250,0.35)]"></span>
            <span>Dev_Matrix</span>
          </div>
          <div class="text-[8px] font-mono uppercase tracking-widest text-gray-500">GitHub DB</div>
        </div>
        <div class="grid grid-cols-2 gap-4 md:flex md:flex-wrap md:gap-8 md:items-center mt-4">
          <div class="flex flex-col gap-1">
             <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Total Contributions</span>
             <span class="text-xl md:text-2xl font-bold font-mono text-sky tracking-tight" id="dev-commits">0</span>
          </div>
          <div class="flex flex-col gap-1">
             <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Total Stars</span>
             <span class="text-xl md:text-2xl font-bold font-mono text-yellow-400 tracking-tight" id="dev-stars-matrix">0</span>
          </div>
          <div class="flex flex-col gap-1">
             <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Repositories</span>
             <span class="text-xl md:text-2xl font-bold font-mono text-electric-purple tracking-tight" id="dev-repos-matrix">0</span>
          </div>
          <div class="flex flex-col gap-1">
             <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Longest Streak</span>
             <span class="text-xl md:text-2xl font-bold font-mono text-green-400 tracking-tight" id="dev-streak-matrix">0d</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Location Map -->
    <div class="bento-item bento-location glass-panel overflow-hidden border-white/5">
      <LocationMap />
    </div>

    <!-- Clicker Challenge -->
    <div class="bento-item bento-clicker glass-panel p-4">
      <Clicker />
    </div>

    <!-- Terminal Events -->
    <div class="bento-item bento-commits glass-panel p-4 flex flex-col">
      <div class="flex justify-between items-center mb-3">
        <div class="text-[8px] font-mono text-gray-500 uppercase tracking-widest">Kernel_Log</div>
        <div class="flex gap-1">
          <div class="w-1 h-1 bg-green-500"></div>
          <div class="w-1 h-1 bg-yellow-500"></div>
          <div class="w-1 h-1 bg-red-500"></div>
        </div>
      </div>
      <div id="recent-commits" class="space-y-2 text-[8px] font-mono max-h-[120px] overflow-y-auto custom-scrollbar pr-2">
        <!-- Commits -->
      </div>
    </div>
  </div>
</section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "metrics"
      "productivity"
      "overview"
      "location"
      "clicker"
      "commits";
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, auto);
      grid-template-areas:
        "metrics productivity overview overview"
        "location clicker overview overview"
        "commits commits overview overview";
      grid-auto-rows: minmax(160px, auto);
    }
  }

  .bento-metrics { grid-area: metrics; }
  .bento-productivity { grid-area: productivity; }
  .bento-posts { grid-area: overview; }
  .bento-location { grid-area: location; }
  .bento-clicker { grid-area: clicker; }
  .bento-commits { grid-area: commits; }

  /* HUD Scanline Effect */
  .hud-scan {
    position: relative;
    overflow: hidden;
  }
  .hud-scan::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%),
                linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
    background-size: 100% 2px, 3px 100%;
    pointer-events: none;
    z-index: 2;
  }
</style>

<script>
  import Chart from "chart.js/auto";

  function initEliteDashboard() {
    const uptimeEl = document.getElementById("system-uptime");
    const startTime = Date.now() - (Math.random() * 1000000); // Simulated boot time

    setInterval(() => {
      const diff = Date.now() - startTime;
      const h = Math.floor(diff / 3600000).toString().padStart(2, '0');
      const m = Math.floor((diff % 3600000) / 60000).toString().padStart(2, '0');
      const s = Math.floor((diff % 60000) / 1000).toString().padStart(2, '0');
      if (uptimeEl) uptimeEl.textContent = `UPTIME: ${h}:${m}:${s}`;
    }, 1000);

    // Data Fetching Logic (Unified for performance)
    async function fetchAll() {
      await Promise.all([
        fetchDevStats(),
        fetchGitHubEvents(),
        fetchWakaTime(),
        fetchLOC()
      ]);
    }

    async function fetchDevStats() {
      try {
        const response = await fetch(`/api/github/stats?t=${Date.now()}`);
        if (!response.ok) return;
        const stats = await response.json();

        const updateText = (id: string, val: any) => {
          const el = document.getElementById(id);
          if (el) el.textContent = val?.toLocaleString() || "0";
        };

        updateText("dev-score", stats.score?.toString().padStart(3, '0'));
        updateText("dev-streak", `${stats.streak}d`);
        updateText("dev-streak-matrix", `${stats.streak}d`);
        updateText("dev-stars", stats.stars);
        updateText("dev-stars-matrix", stats.stars);
        updateText("dev-repos", stats.repos);
        updateText("dev-repos-matrix", stats.repos);
        updateText("dev-followers", stats.followers);
        updateText("dev-commits", stats.commits);
        updateText("integrity-val", `${stats.score}%`);

        const badge = document.getElementById("dev-rank-badge");
        if (badge && stats.rank) {
          badge.textContent = `RANK: ${stats.rank}`;
          badge.style.opacity = "1";
        }

        const progress = document.getElementById("score-progress");
        if (progress && stats.score) progress.style.width = `${stats.score}%`;
      } catch (err) {}
    }

    async function fetchLOC() {
      try {
        const response = await fetch(`/api/github/loc?t=${Date.now()}`);
        if (!response.ok) return;
        const data = await response.json();

        const container = document.getElementById("loc-stats");
        const total = document.getElementById("loc-total");
        const added = document.getElementById("loc-added");

        if (total) total.textContent = data.loc;
        if (added) added.textContent = data.added;
        if (container) container.style.opacity = "1";
      } catch (err) {}
    }

    async function fetchGitHubEvents() {
      const container = document.getElementById("recent-commits");
      if (!container) return;
      try {
        const res = await fetch(`/api/github/events?t=${Date.now()}`);
        const data = await res.json();
        if (data.commits) {
          container.innerHTML = data.commits.slice(0, 6).map((c: any) => `
            <div class="flex items-start gap-2 group/log">
              <span class="text-neon-cyan opacity-50">#</span>
              <div class="flex-1 overflow-hidden">
                <div class="flex justify-between">
                  <span class="text-white font-bold truncate hover:text-neon-cyan cursor-pointer transition-colors">${c.message}</span>
                  <span class="opacity-30 flex-shrink-0">${c.time}</span>
                </div>
                <div class="flex gap-2 opacity-40 group-hover/log:opacity-100 transition-opacity">
                  <span>${c.repo}</span>
                  <span>>></span>
                  <span>${c.hash}</span>
                </div>
              </div>
            </div>
          `).join("");
        }
      } catch (e) {}
    }

    async function fetchWakaTime() {
      const canvas = document.getElementById("activityChart") as HTMLCanvasElement;
      if (!canvas) return;

      try {
        const res = await fetch(`/api/wakatime/timeline?t=${Date.now()}`);
        const data = await res.json();

        // Update Metrics
        if (data.metrics) {
          const m = data.metrics;
          const setMetric = (id: string, val: string) => {
            const el = document.getElementById(id);
            if (el) el.textContent = val;
          };
          setMetric("metric-intensity", `${m.intensity}h`);
          setMetric("metric-focus", `${m.focus}%`);
          setMetric("metric-top-lang", m.top_language);
          const bar = document.getElementById("consistency-bar");
          if (bar) bar.style.width = `${m.consistency}%`;

          const vBadge = document.getElementById("velocity-badge");
          if (vBadge && m.velocity > 0) {
            vBadge.textContent = `+${m.velocity}% VEL`;
            vBadge.style.opacity = "1";
          }
        }

        // Radar Sparkline
        const radar = document.getElementById("radar-polygon");
        if (radar && data.days) {
           const totals = data.days.map((d: any) => d.total_seconds);
           const max = Math.max(...totals, 1);
           const points = totals.map((t: number, i: number) => {
              const angle = (i / 7) * Math.PI * 2;
              const r = (t / max) * 80;
              return `${100 + Math.cos(angle) * r},${100 + Math.sin(angle) * r}`;
           }).join(" ");
           radar.setAttribute("points", points);
        }

        // Main Chart
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        const getCol = (v: string) => getComputedStyle(document.documentElement).getPropertyValue(v).trim();

        const labels = data.days.map((d: any) => new Date(d.date).toLocaleDateString('en-US', { weekday: 'narrow' }));
        const totals: number[] = data.days.map((d: any) => d.total_seconds / 3600);
        const indexLine: number[] = totals.map((value: number, index: number, arr: number[]) => {
          if (index < 2) return value;
          return (arr[index] + arr[index - 1] + arr[index - 2]) / 3;
        });

        new Chart(canvas, {
          type: 'bar',
          data: {
            labels,
            datasets: [{
              label: 'Load',
              data: totals,
              backgroundColor: getCol("--color-blue") + '33',
              borderColor: getCol("--color-sky"),
              borderWidth: 1,
              borderRadius: 6,
              barPercentage: 0.7,
              categoryPercentage: 0.75
            }, {
              type: 'line',
              label: 'Index',
              data: indexLine,
              borderColor: getCol("--color-blue"),
              borderWidth: 2.5,
              pointRadius: 0,
              tension: 0.4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, ticks: { font: { family: 'monospace', size: 8 }, color: 'rgba(205, 214, 244, 0.45)' } },
              y: { grid: { color: 'rgba(137, 180, 250, 0.06)' }, ticks: { font: { family: 'monospace', size: 8 }, color: 'rgba(205, 214, 244, 0.45)' } }
            }
          }
        });

        const totalEl = document.getElementById("total-contributions");
        const lifetime = data.days.reduce((acc: number, d: any) => acc + d.total_seconds, 0) / 3600;
        if (totalEl) totalEl.textContent = lifetime.toFixed(1) + 'h';

      } catch (e) {}
    }

    fetchAll();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initEliteDashboard);
  } else {
    initEliteDashboard();
  }
  document.addEventListener("astro:page-load", initEliteDashboard);
</script>
