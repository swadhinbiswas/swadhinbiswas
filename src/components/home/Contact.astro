---
import { getDynamicConfig } from "../../lib/config";

const siteConfig = await getDynamicConfig();
const email = siteConfig.email || "";
---

<section class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-3 reveal">
        <p class="text-eyebrow">Contact</p>
      </div>
      <div class="md:col-span-9 reveal reveal-delay-1">
        <p class="prose-mono">
          Best way to reach me is email.
        </p>
        {email ? (
          <a
            href={`mailto:${email}`}
            class="text-mono mt-4 inline-block break-all text-base text-white transition-colors hover:text-[var(--color-fg-muted)]"
          >
            {email} →
          </a>
        ) : (
          <p class="prose-mono mt-4 italic">No email configured yet.</p>
        )}
        <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-mono text-xs text-[var(--color-fg-subtle)]">
          {siteConfig.links?.github && (
            <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              GitHub
            </a>
          )}
          {siteConfig.links?.linkedin && (
            <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              LinkedIn
            </a>
          )}
          {siteConfig.links?.twitter && (
            <a href={siteConfig.links.twitter} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              X
            </a>
          )}
          {siteConfig.links?.youtube && (
            <a href={siteConfig.links.youtube} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              YouTube
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
