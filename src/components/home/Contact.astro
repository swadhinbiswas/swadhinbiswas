---
import { getDynamicConfig } from "../../lib/config";

const siteConfig = await getDynamicConfig();
const email = siteConfig.email || "";
---

<section class="section border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 sm:p-12 lg:p-16 reveal">
      <div class="bg-glow" aria-hidden="true"></div>

      <div class="relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <p class="section-eyebrow">Contact</p>
          <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl">
            Let's build something <span class="text-gradient-accent">together</span>.
          </h2>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href={`mailto:${email}`} class="btn btn-primary btn-lg">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-10 6L2 7"/>
              </svg>
              {email || "Email me"}
            </a>
            <a href="/contact" class="btn btn-secondary btn-lg">
              Contact form
            </a>
          </div>
        </div>

        {siteConfig.location && (
          <div class="lg:col-span-4">
            <div class="card p-6">
              <p class="text-eyebrow">Based in</p>
              <p class="mt-2 text-base text-white">{siteConfig.location}</p>
              {siteConfig.timezone && (
                <>
                  <div class="divider my-5"></div>
                  <p class="text-eyebrow">Timezone</p>
                  <p class="mt-2 text-sm text-white">{siteConfig.timezone}</p>
                </>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
