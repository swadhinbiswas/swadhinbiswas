---
import { db, experiences } from "../../db";
import { asc } from "drizzle-orm";

interface Experience {
  id: number;
  company: string;
  role: string;
  url?: string;
  logoUrl?: string;
  startDate: string;
  endDate?: string;
  details?: string;
}

let experiencesList: Experience[] = [];
try {
  const rows = await db.select().from(experiences).orderBy(asc(experiences.startDate));
  experiencesList = rows as Experience[];
} catch {
  experiencesList = [];
}

function formatDate(s?: string) {
  if (!s) return "Present";
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

// Build a concise, premium timeline.
interface TimelineItem {
  year: string;
  title: string;
  org?: string;
  detail?: string;
  url?: string;
}

const timeline: TimelineItem[] = experiencesList.map((e) => ({
  year: formatDate(e.startDate).split(" ")[1] || "",
  title: e.role,
  org: e.company,
  detail: e.details,
  url: e.url,
}));

// Filter to last ~6 entries, newest first
timeline.reverse();
const visible = timeline.slice(0, 6);

// Always include "today" entry from config
---

<section class="section">
  <div class="container-page">
    <div class="section-header reveal">
      <p class="section-eyebrow">Career Timeline</p>
      <h2 class="section-title">A short, intentional path.</h2>
      <p class="section-description">From early engineering work to founding and scaling products to millions of users.</p>
    </div>

    <div class="relative">
      <div class="absolute left-3 top-0 bottom-0 w-px bg-[var(--color-border)] md:left-1/2" aria-hidden="true"></div>

      <ol class="space-y-12">
        {visible.map((item, i) => (
          <li
            class="relative grid grid-cols-1 items-start gap-6 md:grid-cols-2 reveal"
            style={`transition-delay: ${i * 80}ms`}
          >
            <span
              class="absolute left-3 top-2 z-10 h-2.5 w-2.5 -translate-x-1/2 rounded-full bg-white ring-4 ring-[var(--color-bg)] md:left-1/2"
              aria-hidden="true"
            ></span>

            <div class:list={["pl-10 md:pl-0", i % 2 === 0 ? "md:pr-12 md:text-right" : "md:col-start-2 md:pl-12"]}>
              <p class="text-mono text-sm font-medium text-[var(--color-fg-subtle)]">{item.year}</p>
              <h3 class="mt-2 text-lg font-semibold text-white">
                {item.url ? (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">
                    {item.title}
                  </a>
                ) : (
                  item.title
                )}
              </h3>
              {item.org && <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{item.org}</p>}
              {item.detail && (
                <p class="mt-3 text-sm leading-relaxed text-[var(--color-fg-subtle)]">{item.detail}</p>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>

    {visible.length > 0 && (
      <div class="mt-12 reveal">
        <a href="/about" class="btn btn-secondary">
          View full experience
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
