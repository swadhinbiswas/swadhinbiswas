---
import { db, publications } from "../../db";
import { desc } from "drizzle-orm";

interface Publication {
  id: number;
  title: string;
  url?: string | null;
  venue?: string | null;
  date: string;
  description?: string | null;
}

let pubs: Publication[] = [];
try {
  const rows = await db.select().from(publications).orderBy(desc(publications.date));
  pubs = rows as Publication[];
} catch {
  pubs = [];
}

function formatDate(s: string) {
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<section class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="mb-6 flex items-baseline justify-between reveal">
      <h2 class="panel-title">
        Research<span class="count-badge">{pubs.length || ""}</span>
      </h2>
      {pubs.length > 0 && (
        <a href="/research" class="text-mono text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-white">
          All publications →
        </a>
      )}
    </div>

    {pubs.length === 0 ? (
      <p class="text-sm text-[var(--color-fg-muted)] reveal">
        Publications will appear here once added from the admin panel.
      </p>
    ) : (
      <div class="panel">
        <div class="panel-top"></div>
        {pubs.map((pub) => (
          <a
            href={pub.url || "#"}
            target={pub.url ? "_blank" : undefined}
            rel={pub.url ? "noopener noreferrer" : undefined}
            class="row-card group"
          >
            <div class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] w-14 flex-shrink-0 pt-1">
              {formatDate(pub.date)}
            </div>

            <div class="min-w-0 flex-1 row-card-divider">
              <h3 class="row-card-title">{pub.title}</h3>
              {pub.venue && (
                <p class="row-card-meta">{pub.venue}</p>
              )}
              {pub.description && (
                <p class="prose-mono mt-1 line-clamp-2">{pub.description}</p>
              )}
            </div>

            <div class="row-card-actions">
              {pub.url && (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              )}
            </div>
          </a>
        ))}
        <div class="panel-bottom"></div>
      </div>
    )}
  </div>
</section>
