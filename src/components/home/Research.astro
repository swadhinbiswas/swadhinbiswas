---
import { db, publications } from "../../db";
import { desc } from "drizzle-orm";

interface Publication {
  id: number;
  title: string;
  url?: string | null;
  venue?: string | null;
  date: string;
  description?: string | null;
}

let pubs: Publication[] = [];
try {
  const rows = await db.select().from(publications).orderBy(desc(publications.date));
  pubs = rows as Publication[];
} catch {
  pubs = [];
}

function formatDate(s: string) {
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<section class="section border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="section-header reveal">
      <p class="section-eyebrow">Research & Publications</p>
      <h2 class="section-title">Credibility, on the record.</h2>
      <p class="section-description">
        Published work spanning AI systems, ML infrastructure, and applied research.
      </p>
    </div>

    {pubs.length === 0 ? (
      <div class="card p-12 text-center reveal">
        <p class="text-sm text-[var(--color-fg-muted)]">
          Publications will appear here once added from the admin panel.
        </p>
      </div>
    ) : (
      <div class="space-y-4">
        {pubs.map((pub, i) => (
          <article
            class="card card-hover group p-6 sm:p-8 reveal halo"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
              <div class="md:col-span-2">
                <p class="text-mono text-sm text-[var(--color-fg-subtle)]">
                  {formatDate(pub.date)}
                </p>
              </div>

              <div class="md:col-span-8">
                <h3 class="text-lg font-semibold text-white transition-colors group-hover:text-[var(--color-accent)]">
                  {pub.url ? (
                    <a href={pub.url} target="_blank" rel="noopener noreferrer">
                      {pub.title}
                    </a>
                  ) : (
                    pub.title
                  )}
                </h3>
                {pub.venue && (
                  <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{pub.venue}</p>
                )}
                {pub.description && (
                  <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-[var(--color-fg-muted)]">
                    {pub.description}
                  </p>
                )}
              </div>

              <div class="md:col-span-2 flex md:justify-end">
                {pub.url && (
                  <a
                    href={pub.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-mono text-xs uppercase tracking-widest text-[var(--color-fg-muted)] transition-colors hover:text-white"
                  >
                    Read →
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

    {pubs.length > 0 && (
      <div class="mt-10 reveal">
        <a href="/research" class="btn btn-secondary">
          All publications
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
