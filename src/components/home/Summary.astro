---
import { getDynamicConfig } from "../../lib/config";

const siteConfig = await getDynamicConfig();
const summaryText = siteConfig.bio?.summary || "";
const highlights = siteConfig.highlights || [];
const languages = siteConfig.languages || "";
---

<section class="section">
  <div class="container-narrow">
    <div class="section-head reveal">
      <div>
        <p class="text-eyebrow">Summary</p>
        <h2 class="section-title">What I build</h2>
      </div>
    </div>

    <div class="panel p-6 sm:p-7 reveal reveal-delay-1">
      {summaryText && <p class="summary-text">{summaryText}</p>}

      {highlights.length > 0 && (
        <div class="highlights">
          {highlights.map((item) => (
            <div class="metric-card">
              <p class="metric-label">{item}</p>
            </div>
          ))}
        </div>
      )}

      {languages && (
        <div class="langs">
          <span class="langs-label">Languages</span>
          <span>{languages}</span>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .summary-text {
    color: var(--color-fg-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }
  @media (min-width: 640px) { .highlights { grid-template-columns: repeat(3, 1fr); } }
  .metric-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-fg);
  }
  .langs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: center;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-edge);
    font-size: 0.78rem;
    color: var(--color-fg-subtle);
  }
  .langs-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-2);
    font-weight: 600;
  }
</style>
