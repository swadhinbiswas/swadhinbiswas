---
import { getDynamicConfig } from "../../lib/config";

const siteConfig = await getDynamicConfig();
const longBio = siteConfig.bio?.long || "";
const shortBio = siteConfig.bio?.short || "";
const bio = longBio || shortBio;
---

<section class="screen-line-after">
  <div class="container-narrow py-10 sm:py-14">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-3 reveal">
        <p class="text-eyebrow">Summary</p>
      </div>
      <div class="md:col-span-9 reveal reveal-delay-1">
        {bio ? (
          <p class="prose-mono">{bio}</p>
        ) : (
          <p class="prose-mono italic">Bio not set — edit it in the admin panel.</p>
        )}
      </div>
    </div>
  </div>
</section>
