---
import { db, experiences } from "../../db";
import { desc } from "drizzle-orm";

interface Experience {
  id: number;
  company: string;
  role: string;
  url?: string;
  logoUrl?: string;
  startDate: string;
  endDate?: string;
  details?: string;
  companyDescription?: string;
}

let experiencesList: Experience[] = [];
try {
  const rows = await db.select().from(experiences).orderBy(desc(experiences.startDate));
  experiencesList = rows as Experience[];
} catch {
  experiencesList = [];
}

function formatDate(s?: string) {
  if (!s) return "Present";
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<section id="experience" class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="mb-7 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between reveal">
      <div>
        <p class="text-eyebrow">Work history</p>
        <h2 class="mt-2 panel-title">
          Experience<span class="count-badge">{experiencesList.length || ""}</span>
        </h2>
      </div>
      <a href="/about" class="text-mono text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)]">
        View all →
      </a>
    </div>

    {experiencesList.length === 0 ? (
      <div class="portfolio-card px-4 py-8 text-center reveal">
        <p class="text-sm text-[var(--color-fg-muted)]">
          No experience entries yet. Add them from the admin panel.
        </p>
      </div>
    ) : (
      <div class="portfolio-card overflow-hidden">
        {experiencesList.map((exp) => (
          <div class="row-card group md:grid-cols-[auto_1fr_12rem]">
            <div class="row-card-logo mt-0.5" aria-hidden="true">
              {exp.logoUrl ? (
                <img src={exp.logoUrl} alt={exp.company} class="h-5 w-5 object-contain" loading="lazy" />
              ) : (
                exp.company.charAt(0).toUpperCase()
              )}
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-base font-semibold leading-snug text-[var(--color-fg)]">
                {exp.role}
                {exp.company && (
                  <span class="text-[var(--color-fg-muted)]"> at {exp.company}</span>
                )}
              </h3>
              {exp.details && (
                <p class="mt-2 line-clamp-3 text-sm leading-6 text-[var(--color-fg-muted)]">{exp.details}</p>
              )}
            </div>

            <div class="row-card-actions flex flex-col items-end gap-1.5 text-right">
              <span class="text-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                {formatDate(exp.startDate)} - {formatDate(exp.endDate)}
              </span>
              {exp.url && (
                <a href={exp.url} target="_blank" rel="noopener noreferrer" aria-label={`${exp.company} website`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
