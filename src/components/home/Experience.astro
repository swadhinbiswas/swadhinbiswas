---
import { db, experiences } from "../../db";
import { desc } from "drizzle-orm";

interface Experience {
  id: number;
  company: string;
  role: string;
  url?: string;
  logoUrl?: string;
  startDate: string;
  endDate?: string;
  details?: string;
  companyDescription?: string;
}

let experiencesList: Experience[] = [];
try {
  const rows = await db.select().from(experiences).orderBy(desc(experiences.startDate));
  experiencesList = rows as Experience[];
} catch {
  experiencesList = [];
}

function formatDate(s?: string) {
  if (!s) return "Present";
  const d = new Date(s);
  if (isNaN(d.getTime())) return s;
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}
---

<section class="section border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="section-header reveal">
      <p class="section-eyebrow">Experience</p>
      <h2 class="section-title">Where I've shipped real work.</h2>
      <p class="section-description">A focused history of building, leading, and scaling.</p>
    </div>

    {experiencesList.length === 0 ? (
      <div class="card p-12 text-center reveal">
        <p class="text-sm text-[var(--color-fg-muted)]">
          No experience entries yet. Add them from the admin panel.
        </p>
      </div>
    ) : (
      <div class="space-y-4">
        {experiencesList.map((exp, i) => (
          <article
            class="card card-hover group p-6 sm:p-8 reveal halo"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:items-start">
              <!-- Logo / monogram -->
              <div class="md:col-span-2">
                <div class="flex h-12 w-12 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface-2)] text-base font-semibold text-white">
                  {exp.logoUrl ? (
                    <img src={exp.logoUrl} alt={exp.company} class="h-7 w-7 object-contain" loading="lazy" />
                  ) : (
                    exp.company.charAt(0).toUpperCase()
                  )}
                </div>
              </div>

              <!-- Body -->
              <div class="md:col-span-7">
                <h3 class="text-lg font-semibold text-white">
                  {exp.role}
                </h3>
                <p class="mt-1 text-sm text-[var(--color-fg-muted)]">
                  {exp.url ? (
                    <a href={exp.url} target="_blank" rel="noopener noreferrer" class="hover:text-white">
                      {exp.company}
                    </a>
                  ) : (
                    exp.company
                  )}
                </p>
                {exp.companyDescription && (
                  <p class="mt-2 text-sm text-[var(--color-fg-subtle)]">{exp.companyDescription}</p>
                )}
                {exp.details && (
                  <p class="mt-4 max-w-2xl text-[15px] leading-relaxed text-[var(--color-fg-muted)]">
                    {exp.details}
                  </p>
                )}
              </div>

              <!-- Date -->
              <div class="md:col-span-3 md:text-right">
                <p class="text-mono text-sm text-[var(--color-fg-subtle)]">
                  {formatDate(exp.startDate)} — {formatDate(exp.endDate)}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
