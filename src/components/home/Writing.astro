---
import { db, posts } from "../../db";
import { desc, eq } from "drizzle-orm";

interface Post {
  slug: string;
  title: string;
  description: string;
  publishedAt: number | Date;
  tags?: string;
}

let recent: Post[] = [];
try {
  const rows = await db
    .select()
    .from(posts)
    .where(eq(posts.draft, false))
    .orderBy(desc(posts.publishedAt))
    .limit(3);
  recent = rows as Post[];
} catch {
  recent = [];
}

function formatDate(p: number | Date) {
  const d = typeof p === "number" ? new Date(p * 1000) : new Date(p);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

function safeJSON(s: any): string[] {
  try { return JSON.parse(s); } catch { return []; }
}
---

<section class="section border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end reveal">
      <div>
        <p class="section-eyebrow">Writing</p>
        <h2 class="section-title mt-3">Recent notes.</h2>
        <p class="section-description mt-3 max-w-xl">
          Essays on systems, ML infrastructure, and engineering practice.
        </p>
      </div>
      <a href="/posts" class="btn btn-secondary btn-sm">
        All writing
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    {recent.length === 0 ? (
      <div class="card p-12 text-center reveal">
        <p class="text-sm text-[var(--color-fg-muted)]">
          Articles will appear here once published from the admin panel.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {recent.map((post, i) => {
          const tags = safeJSON(post.tags);
          return (
            <a
              href={`/posts/${post.slug}`}
              class="card card-hover halo group p-6 reveal flex flex-col"
              style={`transition-delay: ${i * 60}ms`}
            >
              <p class="text-mono text-xs text-[var(--color-fg-subtle)]">
                {formatDate(post.publishedAt)}
              </p>
              <h3 class="mt-4 text-base font-semibold text-white transition-colors group-hover:text-[var(--color-accent)] line-clamp-2">
                {post.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-fg-muted)] line-clamp-3">
                {post.description}
              </p>
              {tags.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-1.5">
                  {tags.slice(0, 2).map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    )}
  </div>
</section>
