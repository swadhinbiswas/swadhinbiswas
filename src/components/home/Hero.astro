---
import { getDynamicConfig } from "../../lib/config";
import { env } from "../../lib/env";
import GithubGraph from "./GithubGraph";

const siteConfig = await getDynamicConfig();
const author = siteConfig.author || env.siteName;
const [firstName, ...rest] = author.split(" ");
const lastName = rest.join(" ");
const shortBio = siteConfig.bio?.short || "";
const longBio = siteConfig.bio?.long || "";
const initials = (firstName?.[0] || "") + (lastName?.[0] || "");

const heroBlurb = (longBio || shortBio);
const eyebrow = siteConfig.description
  ? (siteConfig.description.length > 60
      ? siteConfig.description.split(/(?<=[.!?])\s+/)[0]
      : siteConfig.description)
  : "";

const locationLine = [siteConfig.location, siteConfig.timezone]
  .filter(Boolean)
  .join(" · ");

const projectsCount = siteConfig.featuredProjects?.length || 0;
const experienceCount = siteConfig.experience?.length || 0;
const skillCount = siteConfig.skills?.length || 0;
const focusLabel = siteConfig.bio?.focusLabel || "Portfolio";
const profileImage = "/profile.jpg";

const githubUrl = siteConfig.links?.github || "https://github.com/swadhinbiswas";
const githubUsername = githubUrl.split("/").pop() || "swadhinbiswas";

const meta = [
  { label: "Users Impacted", value: "1M+", sub: "Boringrats: built, scaled, acquired" },
  { label: "Acquired '25", value: "1×", sub: "Boringrats — acquired Nov 2025" },
  { label: "Production Systems", value: "3+ yrs", sub: "Data pipelines & ML infra" },
  { label: "Open Source", value: "12+ repos", sub: "Active contributor" }
];
---

<section class="hero-section">
  <div class="container-narrow py-8 sm:py-10">
    <div class="hero-blog-grid reveal">
      <div class="hero-image">
        <img
          src={profileImage}
          alt={author}
          class="hero-avatar"
          loading="eager"
        />
      </div>
      <div>
        <p class="section-kicker">{focusLabel}</p>
        <h1 class="hero-name mt-3 max-w-3xl">
          <span class="text-gradient">{author}</span>
        </h1>
        <div class="mt-3 flex items-center">
          <span class="inline-flex items-center gap-2 rounded-full bg-emerald-500/15 px-3 py-1 text-[11px] font-bold tracking-wider text-emerald-400 border border-emerald-500/30 uppercase text-mono">
            <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
            Open to Mid-level Data/Backend Roles
          </span>
        </div>
        <p class="hero-tagline mt-4 max-w-3xl">
          Co-built a startup to 1M users, got acquired — now building OPNCODEHUB and engineering production data pipelines.
        </p>
      </div>
    </div>

    <div class="mt-8 max-w-3xl reveal reveal-delay-1">
        <p class="hero-body text-[var(--color-fg-muted)]">
          OPNCODEHUB builds open-source tools that make data engineering and ML accessible to developers everywhere. Looking for mid-level backend or data engineering roles in EU teams shipping production systems.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/projects" class="btn btn-primary">View projects</a>
          {siteConfig.email && (
            <a href={`mailto:${siteConfig.email}`} class="btn btn-outline">Let's collaborate</a>
          )}
          {siteConfig.cvUrl && (
            <a href={siteConfig.cvUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
              Resume
            </a>
          )}
        </div>

        <div class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-mono text-xs text-[var(--color-fg-subtle)]">
          {locationLine && <span>{locationLine}</span>}
          {siteConfig.links?.github && (
            <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--color-accent)]">GitHub</a>
          )}
          {siteConfig.links?.linkedin && (
            <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--color-accent)]">LinkedIn</a>
          )}
          {siteConfig.links?.twitter && (
            <a href={siteConfig.links.twitter} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--color-accent)]">X</a>
          )}
        </div>
    </div>

      <aside class="mt-10 reveal reveal-delay-2">
        <p class="text-eyebrow mb-3">At a Glance</p>
        <dl class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {meta.map((m) => (
            <div class="metric-card">
              <dt class="text-mono text-xs text-[var(--color-fg-subtle)]">{m!.label}</dt>
              <dd class="mt-2 text-2xl font-bold text-[var(--color-fg)] sm:text-3xl">{m!.value}</dd>
              <dd class="mt-1 text-xs text-[var(--color-fg-muted)]">{m!.sub}</dd>
            </div>
          ))}
        </dl>

        <div class="terminal-card mt-5 overflow-hidden rounded-md border border-[var(--color-edge)] bg-[#070707] font-mono text-xs text-[var(--color-fg-muted)] shadow-lg">
          <div class="flex items-center justify-between border-b border-[var(--color-edge)] bg-[#101010] px-4 py-2">
            <div class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-[#EF4444]/80"></span>
              <span class="h-2 w-2 rounded-full bg-[#F59E0B]/80"></span>
              <span class="h-2 w-2 rounded-full bg-[#10B981]/80"></span>
            </div>
            <span class="text-[10px] text-[var(--color-fg-subtle)] text-mono">guest@swadhin-desktop:~</span>
            <div class="w-9"></div>
          </div>
          <div class="p-4 space-y-3.5">
            <div>
              <span class="text-emerald-400">$</span> <span class="text-[var(--color-fg)]">whoami</span>
              <div class="mt-1 text-[var(--color-fg-muted)]">Backend Engineer · Co-founder · 6+ years building production systems</div>
            </div>
            <div>
              <span class="text-emerald-400">$</span> <span class="text-[var(--color-fg)]">current_focus</span>
              <div class="mt-1 text-[var(--color-fg-muted)]">Data Engineering · MLOps · AI Systems · Open Source</div>
            </div>
            <div>
              <span class="text-emerald-400">$</span> <span class="text-[var(--color-fg)]">currently_building</span>
              <div class="mt-1 text-[var(--color-fg-muted)]">OPNCODEHUB — Open-source developer tools and ecosystems</div>
            </div>
            <div>
              <span class="text-emerald-400">$</span> <span class="text-[var(--color-fg)]">seeking</span>
              <div class="mt-1 text-emerald-400">EU Relocation · Germany · Netherlands · Austria</div>
            </div>
          </div>
        </div>

        <div class="panel mt-5 p-4 reveal reveal-delay-3">
          <div class="mb-3 flex items-center justify-between">
            <span class="text-eyebrow">GitHub Activity</span>
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-xs text-mono text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors">
              @{githubUsername}
            </a>
          </div>
          <GithubGraph username={githubUsername} client:visible />
        </div>
      </aside>
  </div>
</section>

<style>
  .hero-section {
    margin-bottom: 3rem;
  }

  .hero-blog-grid {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .hero-image {
    flex-shrink: 0;
  }

  .hero-avatar {
    width: 160px;
    height: 160px;
    object-fit: cover;
    border-radius: 999px;
    background: var(--color-card);
    border: 3px solid var(--color-edge);
    box-shadow: 0 8px 32px rgba(199, 146, 234, 0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-avatar:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(199, 146, 234, 0.3);
  }

  .hero-name {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero-tagline {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    line-height: 1.6;
    color: var(--color-fg-muted);
  }

  .hero-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero-blog-grid {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .hero-avatar {
      width: 120px;
      height: 120px;
    }
  }
</style>
