---
import { getDynamicConfig } from "../../lib/config";
import { env } from "../../lib/env";

const siteConfig = await getDynamicConfig();
const author = siteConfig.author || env.siteName;
const [firstName, ...rest] = author.split(" ");
const lastName = rest.join(" ");
const shortBio = siteConfig.bio?.short || "";
const longBio = siteConfig.bio?.long || "";
const cvUrl = siteConfig.cvUrl;
const initials = (firstName?.[0] || "") + (lastName?.[0] || "");
const heroBlurb = (longBio || shortBio).split(/(?<=[.!?])\s+/)[0] || shortBio;
---

<section class="relative overflow-hidden">
  <div class="bg-grid absolute inset-0 -z-10" aria-hidden="true"></div>
  <div class="bg-glow" aria-hidden="true"></div>

  <div class="container-page relative pt-20 pb-24 sm:pt-28 sm:pb-32 lg:pt-36 lg:pb-40">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-12">
      <!-- Copy -->
      <div class="lg:col-span-7">
        {siteConfig.description && (
          <div class="reveal">
            <span class="section-eyebrow">
              {siteConfig.description.length > 60
                ? siteConfig.description.split(/(?<=[.!?])\s+/)[0]
                : siteConfig.description}
            </span>
          </div>
        )}

        <h1 class="text-display mt-6 reveal reveal-delay-1 text-4xl text-white sm:text-5xl lg:text-[4.5rem]">
          <span class="block text-gradient">{firstName}</span>
          <span class="block text-gradient-accent">{lastName}</span>
        </h1>

        {heroBlurb && (
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-fg-muted)] reveal reveal-delay-2 sm:text-xl">
            {heroBlurb}
          </p>
        )}

        <div class="mt-10 flex flex-wrap items-center gap-3 reveal reveal-delay-4">
          <a href={cvUrl || "/cv"} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
            <span>View Resume</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
            </svg>
          </a>
          <a href="/projects" class="btn btn-secondary btn-lg">
            <span>View Projects</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/contact" class="btn btn-ghost btn-lg">
            Book a Call
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-[var(--color-fg-subtle)] reveal reveal-delay-5">
          {siteConfig.links?.github && (
            <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 transition-colors hover:text-white">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {siteConfig.links?.linkedin && (
            <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 transition-colors hover:text-white">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
          )}
          {siteConfig.email && (
            <a href={`mailto:${siteConfig.email}`} class="inline-flex items-center gap-2 transition-colors hover:text-white">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-10 6L2 7"/>
              </svg>
              {siteConfig.email}
            </a>
          )}
        </div>
      </div>

      <!-- Right visual: identity card -->
      <div class="lg:col-span-5 reveal reveal-delay-2">
        <div class="relative">
          <div class="card p-8 sm:p-10">
            <div class="flex items-center gap-4">
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-white to-[var(--color-fg-subtle)] text-base font-semibold text-black"
                aria-hidden="true"
              >
                {initials.toUpperCase() || "S"}
              </div>
              <div>
                <p class="text-sm font-medium text-white">{author}</p>
              </div>
            </div>

            {siteConfig.location && (
              <div class="divider my-6"></div>
            )}

            <dl class="space-y-4 text-sm">
              {siteConfig.seo?.worksFor?.name && (
                <div class="flex items-center justify-between">
                  <dt class="text-[var(--color-fg-subtle)]">Works at</dt>
                  <dd class="text-white">{siteConfig.seo.worksFor.name}</dd>
                </div>
              )}
              {siteConfig.location && (
                <div class="flex items-center justify-between">
                  <dt class="text-[var(--color-fg-subtle)]">Based in</dt>
                  <dd class="text-white">{siteConfig.location}</dd>
                </div>
              )}
              {siteConfig.timezone && (
                <div class="flex items-center justify-between">
                  <dt class="text-[var(--color-fg-subtle)]">Timezone</dt>
                  <dd class="text-white">{siteConfig.timezone}</dd>
                </div>
              )}
            </dl>

            {siteConfig.skills && siteConfig.skills.length > 0 && (
              <>
                <div class="divider my-6"></div>
                <div class="flex flex-wrap gap-2">
                  {siteConfig.skills.slice(0, 6).map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </div>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
