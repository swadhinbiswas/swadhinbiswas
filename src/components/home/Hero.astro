---
import { getDynamicConfig } from "../../lib/config";
import { env } from "../../lib/env";

const siteConfig = await getDynamicConfig();
const author = siteConfig.author || env.siteName;
const [firstName, ...rest] = author.split(" ");
const lastName = rest.join(" ");
const shortBio = siteConfig.bio?.short || "";
const longBio = siteConfig.bio?.long || "";
const initials = (firstName?.[0] || "") + (lastName?.[0] || "");

const heroBlurb = (longBio || shortBio).split(/(?<=[.!?])\s+/)[0] || shortBio;
const eyebrow = siteConfig.description
  ? (siteConfig.description.length > 60
      ? siteConfig.description.split(/(?<=[.!?])\s+/)[0]
      : siteConfig.description)
  : "";

const locationLine = [siteConfig.location, siteConfig.timezone]
  .filter(Boolean)
  .join(" · ");

const meta = [
  siteConfig.location ? { label: "Based in", value: siteConfig.location } : null,
  siteConfig.timezone ? { label: "Timezone", value: siteConfig.timezone } : null,
  siteConfig.email ? { label: "Email", value: siteConfig.email, href: `mailto:${siteConfig.email}` } : null,
].filter(Boolean);
---

<section class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="panel">
      <div class="panel-top"></div>

      <div class="pattern-dots">
        <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10">
          <!-- Eyebrow -->
          {eyebrow && (
            <p class="text-eyebrow reveal">{eyebrow}</p>
          )}

          <!-- Identity row: avatar + name + role tag -->
          <div class="flex items-start gap-5 reveal reveal-delay-1">
            <div class="avatar" aria-hidden="true">
              {(initials || "S").toUpperCase()}
            </div>
            <div class="min-w-0 flex-1">
              <h1 class="text-display text-3xl sm:text-4xl">
                <span class="text-gradient">{author}</span>
              </h1>
              {locationLine && (
                <p class="text-mono mt-2 text-xs text-[var(--color-fg-subtle)]">
                  {locationLine}
                </p>
              )}
            </div>
          </div>

          <!-- Bio paragraph -->
          {heroBlurb && (
            <p class="prose-mono max-w-prose reveal reveal-delay-2">
              {heroBlurb}
            </p>
          )}

          <!-- Meta grid (key/value pairs) -->
          {meta.length > 0 && (
            <dl class="grid grid-cols-1 gap-3 border-t border-dashed border-[var(--color-edge)] pt-5 sm:grid-cols-2 reveal reveal-delay-3">
              {meta.map((m) => (
                <div class="flex items-baseline justify-between gap-3 text-sm">
                  <dt class="text-mono text-xs text-[var(--color-fg-subtle)]">{m!.label}</dt>
                  <dd class="truncate text-right text-white">
                    {m!.href ? (
                      <a href={m!.href} class="hover:text-[var(--color-fg-muted)]">
                        {m!.value}
                      </a>
                    ) : (
                      m!.value
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          )}

          <!-- Social row -->
          {(siteConfig.links?.github || siteConfig.links?.linkedin || siteConfig.links?.twitter) && (
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-dashed border-[var(--color-edge)] pt-5 reveal reveal-delay-4">
              {siteConfig.links?.github && (
                <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="text-mono text-xs text-[var(--color-fg-muted)] transition-colors hover:text-white">
                  GitHub
                </a>
              )}
              {siteConfig.links?.linkedin && (
                <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="text-mono text-xs text-[var(--color-fg-muted)] transition-colors hover:text-white">
                  LinkedIn
                </a>
              )}
              {siteConfig.links?.twitter && (
                <a href={siteConfig.links.twitter} target="_blank" rel="noopener noreferrer" class="text-mono text-xs text-[var(--color-fg-muted)] transition-colors hover:text-white">
                  X
                </a>
              )}
              {siteConfig.links?.youtube && (
                <a href={siteConfig.links.youtube} target="_blank" rel="noopener noreferrer" class="text-mono text-xs text-[var(--color-fg-muted)] transition-colors hover:text-white">
                  YouTube
                </a>
              )}
              {siteConfig.cvUrl && (
                <a href={siteConfig.cvUrl} target="_blank" rel="noopener noreferrer" class="text-mono text-xs text-[var(--color-fg-muted)] transition-colors hover:text-white">
                  Resume →
                </a>
              )}
            </div>
          )}
        </div>
      </div>

      <div class="panel-bottom"></div>
    </div>
  </div>
</section>
