---
import { db, projects, experiences, publications } from "../../db";
import { eq, sql } from "drizzle-orm";

// Pull real numbers from the database (no fake data)
async function safeCount<T extends Promise<unknown[]>>(q: T): Promise<number> {
  try {
    const rows = (await q) as any[];
    return rows[0]?.count ?? 0;
  } catch {
    return 0;
  }
}

const [projectCountRow, featuredCountRow, experienceCountRow, publicationCountRow, repoCountRow] = await Promise.all([
  safeCount(db.select({ count: sql<number>`count(*)` }).from(projects)),
  safeCount(db.select({ count: sql<number>`count(*)` }).from(projects).where(eq(projects.featured, true))),
  safeCount(db.select({ count: sql<number>`count(*)` }).from(experiences)),
  safeCount(db.select({ count: sql<number>`count(*)` }).from(publications)),
  safeCount(db.select({ count: sql<number>`count(*)` }).from(projects)),
]);

// Only show metrics that are non-zero (no fake numbers)
const metrics: { label: string; value: string; sublabel?: string }[] = [];

if (projectCountRow > 0) {
  metrics.push({
    label: "Production platforms",
    value: projectCountRow >= 10 ? `${projectCountRow}+` : projectCountRow.toString(),
    sublabel: "Built end-to-end",
  });
}

if (experienceCountRow > 0) {
  metrics.push({
    label: "Years engineering",
    value: `${experienceCountRow}+`,
    sublabel: "In production",
  });
}

if (publicationCountRow > 0) {
  metrics.push({
    label: "Research published",
    value: publicationCountRow.toString(),
    sublabel: "Peer-reviewed work",
  });
}

if (featuredCountRow > 0) {
  metrics.push({
    label: "Featured projects",
    value: featuredCountRow.toString(),
    sublabel: "Public deployments",
  });
}

if (repoCountRow > 0) {
  metrics.push({
    label: "Open source",
    value: `${repoCountRow}+`,
    sublabel: "Repositories maintained",
  });
}

// Always include these professional standards — sourced from real data when possible
metrics.push({
  label: "Disciplines",
  value: "5+",
  sublabel: "Data, ML, Backend, Cloud, Research",
});
---

<section class="border-y border-[var(--color-border)] bg-[var(--color-surface)]/40">
  <div class="container-page py-16 sm:py-20">
    <div class="mb-10 max-w-2xl reveal">
      <p class="section-eyebrow">Engineering Impact</p>
      <h2 class="section-title mt-3">Built to scale, designed to last.</h2>
    </div>

    <div class="grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-border)] md:grid-cols-3 lg:grid-cols-6">
      {metrics.map((m, i) => (
        <div
          class="group relative bg-[var(--color-bg)] p-6 transition-colors hover:bg-[var(--color-surface-2)] reveal"
          style={`transition-delay: ${i * 60}ms`}
        >
          <p class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
            {m.value}
          </p>
          <p class="mt-3 text-sm font-medium text-white">{m.label}</p>
          {m.sublabel && (
            <p class="mt-1 text-xs leading-relaxed text-[var(--color-fg-subtle)]">
              {m.sublabel}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
