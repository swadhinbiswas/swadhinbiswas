---
import { db, skills } from "../../db";
import { asc } from "drizzle-orm";

interface Skill {
  id: number;
  name: string;
  category?: string;
}

let all: Skill[] = [];
try {
  const rows = await db.select().from(skills).orderBy(asc(skills.order));
  all = rows as Skill[];
} catch {
  all = [];
}

function initials(name: string) {
  return name
    .replace(/[^a-zA-Z0-9+#.]/g, "")
    .slice(0, 3)
    .toUpperCase();
}
---

<section class="screen-line-after">
  <div class="container-narrow py-12 sm:py-16">
    <div class="mb-6 flex items-baseline justify-between reveal">
      <h2 class="panel-title">
        Stack<span class="count-badge">{all.length || ""}</span>
      </h2>
    </div>

    {all.length === 0 ? (
      <p class="text-sm text-[var(--color-fg-muted)] reveal">
        Skills will appear here once added from the admin panel.
      </p>
    ) : (
      <div class="flex flex-wrap gap-2 reveal">
        {all.map((s) => (
          <a
            href={`#${s.name.toLowerCase()}`}
            class="icon-chip"
            title={s.name}
            aria-label={s.name}
          >
            {initials(s.name)}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
