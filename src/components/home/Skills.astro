function iconFor(name: string): { type: "skillicons" | "devicon"; src: string } | null {
  const key = name.toLowerCase();
  if (skilliconsMap[key]) {
    return { type: "skillicons", src: `https://skillicons.dev/icons?i=${skilliconsMap[key]}&theme=dark` };
  }
  if (deviconsFallback[key]) {
    return { type: "devicon", src: deviconsFallback[key] };
  }
  return null;
}

function initials(name: string) {
  return name
    .replace(/[^a-zA-Z0-9+#.]/g, "")
    .slice(0, 3)
    .toUpperCase();
}

const grouped = all.reduce<Record<string, Skill[]>>((acc, skill) => {
  const category = skill.category || "general";
  acc[category] = acc[category] || [];
  acc[category].push(skill);
  return acc;
}, {});

const categoryOrder: Record<string, number> = {
  "language": 1,
  "framework": 2,
  "data engineering": 3,
  "database": 4,
  "devops": 5,
  "ai": 6,
  "general": 7,
};

const sortedCategories = Object.entries(grouped).sort(
  ([a], [b]) => (categoryOrder[a] || 99) - (categoryOrder[b] || 99)
);

const categoryLabel = (category: string) =>
  category
    .split(/[-_\s]+/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
---

<section id="skills" class="skills-section">
  <div class="container-narrow py-12 sm:py-16">
    <div class="mb-8 flex items-baseline justify-between reveal">
      <div>
        <p class="text-eyebrow">Capabilities</p>
        <h2 class="mt-2 panel-title">
          Stack<span class="count-badge">{all.length || ""}</span>
        </h2>
      </div>
      <a href="/skills" class="text-mono text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)]">
        View all →
      </a>
    </div>

    {all.length === 0 ? (
      <p class="portfolio-card p-6 text-sm text-[var(--color-fg-muted)] reveal">
        Skills will appear here once added from the admin panel.
      </p>
    ) : (
      <div class="space-y-6">
        {sortedCategories.slice(0, 3).map(([category, skills]) => {
          const coreSkills = skills.filter(s => s.tier === 'core');
          const workingSkills = skills.filter(s => s.tier !== 'core');
          return (
            <div class="reveal">
              <h3 class="text-sm font-semibold text-[var(--color-fg)] mb-3">{categoryLabel(category)}</h3>
              {coreSkills.length > 0 && (
                <div class="mb-2">
                  <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-accent)] mb-2 block">Core</span>
                  <div class="skills-chip-grid">
                    {coreSkills.map((s) => {
                      const icon = iconFor(s.name);
                      const linkedProjects = s.usedIn ? safeJSON(s.usedIn) : (skillToProjects.get(s.name.toLowerCase()) || []);
                      return (
                        <div class="skill-chip skill-chip-core group" title={s.description || s.name}>
                          <div class="skill-chip-icon">
                            {icon ? (
                              <img src={icon.src} alt={s.name} loading="lazy" class="skill-chip-img" />
                            ) : (
                              <span class="skill-chip-initials">{initials(s.name)}</span>
                            )}
                          </div>
                          <span class="skill-chip-name">{s.name}</span>
                          {linkedProjects.length > 0 && (
                            <span class="skill-chip-count">{linkedProjects.length}</span>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
              {workingSkills.length > 0 && (
                <div>
                  <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] mb-2 block">Working knowledge</span>
                  <div class="skills-chip-grid">
                    {workingSkills.map((s) => {
                      const icon = iconFor(s.name);
                      const linkedProjects = s.usedIn ? safeJSON(s.usedIn) : (skillToProjects.get(s.name.toLowerCase()) || []);
                      return (
                        <div class="skill-chip group" title={s.description || s.name}>
                          <div class="skill-chip-icon">
                            {icon ? (
                              <img src={icon.src} alt={s.name} loading="lazy" class="skill-chip-img" />
                            ) : (
                              <span class="skill-chip-initials">{initials(s.name)}</span>
                            )}
                          </div>
                          <span class="skill-chip-name">{s.name}</span>
                          {linkedProjects.length > 0 && (
                            <span class="skill-chip-count">{linkedProjects.length}</span>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .skills-section {
    border-top: 1px solid var(--color-edge);
  }

  .skills-chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border-radius: 10px;
    border: 1px solid var(--color-edge);
    background: var(--color-card);
    transition: all 0.2s ease;
    cursor: default;
  }

  .skill-chip:hover {
    border-color: var(--color-accent);
    background: var(--color-card-strong);
    transform: translateY(-1px);
  }

  .skill-chip-core {
    border-color: var(--color-accent);
    background: rgba(124, 58, 237, 0.08);
  }

  .skill-chip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .skill-chip-img {
    width: 16px;
    height: 16px;
    object-fit: contain;
  }

  .skill-chip-initials {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .skill-chip-name {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-fg-muted);
    transition: color 0.2s ease;
  }

  .skill-chip:hover .skill-chip-name {
    color: var(--color-fg);
  }

  .skill-chip-count {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-fg-subtle);
    background: rgba(124, 58, 237, 0.1);
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
  }
</style>