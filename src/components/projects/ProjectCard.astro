---
const { project } = Astro.props;

function slug(name: string) {
  return name
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, "")
    .replace(/[\s_-]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const href = `/projects/${slug(project.name)}`;
const tags = project.tags || [];
---

<a
  href={href}
  class="card card-hover halo group p-6 sm:p-7 flex flex-col h-full"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface-2)] text-sm font-semibold text-white">
      {project.name.charAt(0).toUpperCase()}
    </div>
    {project.featured && (
      <span class="text-mono text-[10px] uppercase tracking-widest text-[var(--color-fg-subtle)]">
        Featured
      </span>
    )}
  </div>

  <h3 class="mt-5 text-lg font-semibold tracking-tight text-white transition-colors group-hover:text-[var(--color-accent)]">
    {project.name}
  </h3>

  <p class="mt-3 text-[15px] leading-relaxed text-[var(--color-fg-muted)] line-clamp-3">
    {project.description}
  </p>

  {tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-1.5">
      {tags.slice(0, 4).map((t: string) => (
        <span class="tag">{t}</span>
      ))}
      {tags.length > 4 && (
        <span class="tag text-[var(--color-fg-subtle)]">+{tags.length - 4}</span>
      )}
    </div>
  )}

  <div class="mt-auto pt-6 flex items-center justify-between text-sm">
    <span class="text-[var(--color-fg-muted)] transition-colors group-hover:text-white">
      View case study →
    </span>
    {project.stars > 0 && (
      <span class="text-mono text-xs text-[var(--color-fg-subtle)] inline-flex items-center gap-1">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279L.001 9.306l8.332-1.151z"/></svg>
        {project.stars.toLocaleString()}
      </span>
    )}
  </div>
</a>
