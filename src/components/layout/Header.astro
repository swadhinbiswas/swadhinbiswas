---
import { getDynamicConfig } from "../../lib/config";
import { db, navigationItems } from "../../db";
import { eq, or, asc } from "drizzle-orm";

const siteConfig = await getDynamicConfig();
const pathname = Astro.url.pathname;

let navItems: { label: string; href: string; external?: boolean }[] = [];

try {
  const dbItems = await db
    .select()
    .from(navigationItems)
    .where(or(eq(navigationItems.location, "header"), eq(navigationItems.location, "both")))
    .orderBy(asc(navigationItems.order));

  if (dbItems.length > 0) {
    navItems = dbItems.map((item) => ({
      label: item.label,
      href: item.href,
      external: item.external || false,
    }));
  }
} catch {
  navItems = [];
}

if (navItems.length === 0) {
  navItems = [
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects" },
    { label: "Skills", href: "/skills" },
    { label: "Blog", href: "/posts" },
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" },
  ];
}

const author = siteConfig.author || "Swadhin Biswas";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const socials = [
  siteConfig.links?.github ? { label: "GitHub", href: siteConfig.links.github } : null,
  siteConfig.links?.linkedin ? { label: "LinkedIn", href: siteConfig.links.linkedin } : null,
  siteConfig.links?.twitter ? { label: "Twitter", href: siteConfig.links.twitter } : null,
].filter(Boolean);
---

<aside class="delphi-sidebar">
  <div class="sidebar-header">
    <a href="/" class="brand-text" aria-label={`${author} home`}>
      <strong>{author.toLowerCase().replace(/\s+/g, "")}</strong>
      <span>portfolio</span>
    </a>
    <button class="mobile-menu-toggle" aria-label="Toggle menu" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>

  <nav class="sidebar-nav" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a
        href={item.href}
        target={item.external ? "_blank" : undefined}
        rel={item.external ? "noopener noreferrer" : undefined}
        class:list={["nav-item", isActive(item.href) && "active"]}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        <span class="nav-icon" aria-hidden="true">▸</span>
        {item.label}
      </a>
    ))}

    {socials.length > 0 && (
      <div class="nav-section">
        <h4 class="nav-section-title">Social</h4>
        {socials.map((social) => (
          <a href={social!.href} target="_blank" rel="noopener noreferrer" class="nav-item">
            <span class="nav-icon" aria-hidden="true">↗</span>
            {social!.label}
          </a>
        ))}
      </div>
    )}
  </nav>

  <div class="sidebar-footer">
    Data engineering.<br />
    Backend systems.<br />
    Handmade web.
  </div>
</aside>

<script>
  const bindMenu = () => {
    const button = document.querySelector(".mobile-menu-toggle");
    const nav = document.querySelector(".sidebar-nav");
    const footer = document.querySelector(".sidebar-footer");
    button?.addEventListener("click", () => {
      nav?.classList.toggle("is-open");
      footer?.classList.toggle("is-open");
    });
  };

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", bindMenu);
  else bindMenu();
  document.addEventListener("astro:page-load", bindMenu);
</script>

<style>
  .brand-mark-animated {
    display: inline-flex;
    width: 2.4rem;
    height: 2.4rem;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    transition: transform 0.3s ease;
  }

  .brand-mark-animated:hover {
    transform: rotate(-5deg) scale(1.05);
  }

  .logo-svg {
    width: 100%;
    height: 100%;
  }

  .logo-bg {
    animation: logoPulse 3s ease-in-out infinite alternate;
  }

  .logo-dot {
    animation: dotBlink 2s ease-in-out infinite;
  }

  .logo-text {
    animation: textGlow 3s ease-in-out infinite alternate;
  }

  @keyframes logoPulse {
    0% { opacity: 0.9; }
    100% { opacity: 1; filter: brightness(1.1); }
  }

  @keyframes dotBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @keyframes textGlow {
    0% { filter: drop-shadow(0 0 2px rgba(255,255,255,0.3)); }
    100% { filter: drop-shadow(0 0 6px rgba(255,255,255,0.6)); }
  }
</style>
