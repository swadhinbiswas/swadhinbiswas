---
import { getDynamicConfig } from "../../lib/config";
import { db, navigationItems } from "../../db";
import { eq, or, asc } from "drizzle-orm";

const siteConfig = await getDynamicConfig();
const pathname = Astro.url.pathname;

let navItems: { label: string; href: string; external?: boolean }[] = [];

try {
  const dbItems = await db
    .select()
    .from(navigationItems)
    .where(
      or(
        eq(navigationItems.location, "header"),
        eq(navigationItems.location, "both"),
      ),
    )
    .orderBy(asc(navigationItems.order));

  if (dbItems.length > 0) {
    navItems = dbItems.map((item) => ({
      label: item.label,
      href: item.href,
      external: item.external || false,
    }));
  }
} catch (e) {
  // silent
}

// Static fallback nav — clean labels, no terminal aesthetic
if (navItems.length === 0) {
  navItems = [
    { label: "Projects", href: "/projects" },
    { label: "Writing", href: "/posts" },
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" },
  ];
}

const author = siteConfig.author || "Portfolio";
const initials = author
  .split(" ")
  .map((p) => p[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("")
  .toUpperCase();

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="sticky-nav">
  <div class="container-narrow">
    <div class="flex h-14 items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 font-medium tracking-tight">
        <span
          class="flex h-7 w-7 items-center justify-center rounded-full bg-white text-[11px] font-semibold text-black"
          aria-hidden="true"
        >
          {initials || "S"}
        </span>
        <span class="text-sm text-white">{author}</span>
      </a>

      <nav class="hidden items-center gap-1 md:flex">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-md px-2.5 py-1.5 text-sm transition-colors",
              isActive(item.href)
                ? "text-white"
                : "text-[var(--color-fg-muted)] hover:text-white",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        {siteConfig.cvUrl && (
          <a
            href={siteConfig.cvUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden btn btn-ghost sm:inline-flex"
          >
            Resume
          </a>
        )}
        <a href="/contact" class="btn btn-ghost">
          Contact
        </a>
        <button
          id="mobile-menu-btn"
          class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-edge)] text-white md:hidden"
          aria-label="Open menu"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 hidden bg-[var(--color-bg)]/95 backdrop-blur-xl md:hidden"
  >
    <div class="container-narrow flex h-full flex-col">
      <div class="mt-20 flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="border-b border-[var(--color-edge)] py-5 text-2xl font-medium tracking-tight text-white"
          >
            {item.label}
          </a>
        ))}
        {siteConfig.cvUrl && (
          <a
            href={siteConfig.cvUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex w-fit btn btn-secondary"
          >
            Resume
          </a>
        )}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const close = () => {
    menu?.classList.add("hidden");
    document.body.style.overflow = "";
  };
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    document.body.style.overflow = menu?.classList.contains("hidden") ? "" : "hidden";
  });
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
</script>
