---
import { getDynamicConfig } from "../../lib/config";

const siteConfig = await getDynamicConfig();
const year = new Date().getFullYear();
const author = siteConfig.author || "";

const socials = (siteConfig.socials || []).filter((s) =>
  ["github", "linkedin", "twitter", "youtube", "scholar", "email"].includes(s.icon)
);

const navGroups = [
  {
    label: "Work",
    items: [
      { label: "Projects", href: "/projects" },
      { label: "Research", href: "/research" },
      { label: "Writing", href: "/posts" },
    ],
  },
  {
    label: "Info",
    items: [
      { label: "About", href: "/about" },
      { label: "Uses", href: "/uses" },
      { label: "Contact", href: "/contact" },
    ],
  },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="container-page py-16 sm:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <!-- Brand + CTA -->
      <div class="md:col-span-6">
        <a href="/" class="inline-flex items-center gap-2.5">
          <span
            class="flex h-7 w-7 items-center justify-center rounded-full bg-white text-[11px] font-semibold text-black"
            aria-hidden="true"
          >
            {(author.split(" ").map((p) => p[0]).filter(Boolean).slice(0, 2).join("").toUpperCase()) || "S"}
          </span>
          <span class="text-sm font-medium text-white">{author}</span>
        </a>

        <p class="mt-6 max-w-sm text-[15px] leading-relaxed text-[var(--color-fg-muted)]">
          {siteConfig.bio?.short ||
            "Senior Data Engineer & MLOps Engineer. Open to global opportunities."}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="/contact" class="btn btn-primary">
            Get in touch
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          {siteConfig.cvUrl && (
            <a href={siteConfig.cvUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
              Download CV
            </a>
          )}
        </div>

        {socials.length > 0 && (
          <div class="mt-8 flex items-center gap-2">
            {socials.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.name}
                class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-fg-muted)] transition-colors hover:border-[var(--color-fg-subtle)] hover:text-white"
              >
                {s.icon === "github" && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
                {s.icon === "linkedin" && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                )}
                {s.icon === "twitter" && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {s.icon === "youtube" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                )}
                {s.icon === "scholar" && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
                  </svg>
                )}
                {s.icon === "email" && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="m22 7-10 6L2 7"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Sitemap -->
      {navGroups.map((group) => (
        <div class="md:col-span-3">
          <h3 class="text-xs font-medium uppercase tracking-widest text-[var(--color-fg-subtle)]">
            {group.label}
          </h3>
          <ul class="mt-5 space-y-3">
            {group.items.map((it) => (
              <li>
                <a
                  href={it.href}
                  class="text-sm text-[var(--color-fg-muted)] transition-colors hover:text-white"
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-col-reverse items-start justify-between gap-4 border-t border-[var(--color-border)] pt-8 sm:flex-row sm:items-center">
      <p class="text-xs text-[var(--color-fg-subtle)]">
        © {year} {author}. Built with care.
      </p>
      <p class="text-xs text-[var(--color-fg-subtle)]">
        Designed for performance · Lighthouse 100
      </p>
    </div>
  </div>
</footer>
