---
import { getDynamicConfig } from "../../lib/config";
import { env } from "../../lib/env";

const siteConfig = await getDynamicConfig();
const year = new Date().getFullYear();
const author = siteConfig.author || env.siteName;

const socials = (siteConfig.socials || []).filter((s) =>
  ["github", "linkedin", "twitter", "scholar", "email"].includes(s.icon)
);
---

<footer class="screen-line-before">
  <div class="pattern-stripes">
    <div class="container-narrow py-8">
      <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
        <p class="text-mono text-xs text-[var(--color-fg-subtle)]">
          © {year} {author}
        </p>
        {socials.length > 0 && (
          <div class="flex items-center gap-3">
            {socials.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.name}
                class="text-mono text-xs text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)]"
              >
                {s.icon === "github" && "GitHub"}
                {s.icon === "linkedin" && "LinkedIn"}
                {s.icon === "twitter" && "X"}
                {s.icon === "scholar" && "Scholar"}
                {s.icon === "email" && "Email"}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</footer>
