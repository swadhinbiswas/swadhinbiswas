# ============================================
# Database Configuration (Turso/libSQL)
# ============================================
# For local development with SQLite, you can use:
# TURSO_DATABASE_URL="file:local.db"
# TURSO_AUTH_TOKEN=""
#
# For production with Turso:
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# ============================================
# Redis Configuration (Optional - for caching)
# ============================================
# Upstash Redis or local Redis
REDIS_URL="redis://localhost:6379"
# or use KV_REDIS_URL for Vercel KV

# ============================================
# Storage Configuration (Optional - for image uploads)
# ============================================
# Cloudflare R2 or compatible S3 storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ============================================
# External API Keys (Optional)
# ============================================
# GitHub API for activity metrics
# If not configured, the site will show placeholder data
GITHUB_TOKEN=""

# WakaTime for coding activity tracking
# If not configured, the site will show placeholder data
WAKATIME_API_KEY=""

# ============================================
# Contact Form (Telegram)
# ============================================
BOT_TOKEN=""
CHAT_ID=""

# ============================================
# Admin Credentials
# ============================================
